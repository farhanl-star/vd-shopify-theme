<script>
  document.addEventListener("DOMContentLoaded", function () {

    const transom = document.querySelector('.door-preview-transom');
    const bottom = document.querySelector('.door-preview-bottom');

    function syncWidth() {
      if (!transom || !bottom) return;
      transom.style.width = bottom.offsetWidth + 'px';
    }

    // Run initially
    syncWidth();

    // Run on window resize
    window.addEventListener('resize', syncWidth);

    // Run on option click/change
    document.querySelectorAll('.common-check-option').forEach(el => {
      el.addEventListener('click', () => {
        setTimeout(syncWidth, 100);
      });

      el.addEventListener('change', () => {
        setTimeout(syncWidth, 100);
      });
    });

    // 🔥 Auto-detect DOM changes (Shopify dynamic updates)
    const observer = new MutationObserver(() => {
      syncWidth();
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true
    });

  });

  document.addEventListener("DOMContentLoaded", function () {

    const layout = document.querySelector('.door-preview-layout');

    function updateDoorClass() {
      const input = document.querySelector('[data-choice-value="double_door"] input');

      if (input && input.checked) {
        layout.classList.add('is-double-door');
    }
    else {
        layout.classList.remove('is-double-door');
      }
    }

    // Run initially
    updateDoorClass();

    // Listen for all input changes
    document.querySelectorAll('[data-choice-value] input').forEach(input => {
      input.addEventListener('change', updateDoorClass);
    });

  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    // Plus button
    document.querySelectorAll(".qty-btn.plus").forEach(function (button) {
      button.addEventListener("click", function () {
        let input = this.parentElement.querySelector('input[name="quantity"]');
        let currentVal = parseInt(input.value) || 1;

        input.value = currentVal + 1;

        // Trigger change event
        input.dispatchEvent(new Event('change'));
      });
    });

    // Minus button
    document.querySelectorAll(".qty-btn.minus").forEach(function (button) {
      button.addEventListener("click", function () {
        let input = this.parentElement.querySelector('input[name="quantity"]');
        let currentVal = parseInt(input.value) || 1;
        let min = parseInt(input.getAttribute("min")) || 1;

        if (currentVal > min) {
          input.value = currentVal - 1;

          // Trigger change event
          input.dispatchEvent(new Event('change'));
        }
      });
    });

  });
</script>
