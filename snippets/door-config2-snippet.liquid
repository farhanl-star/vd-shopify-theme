    <div class="door-configurator__panel">

  {%- comment -%}
    Dynamic options source (Metaobjects):
    - Product metafield: custom.door_config_options (List of Metaobject references: config_option)
    - config_option fields used:
      - key (id), label, input_type (select|number|checkbox|radio|dimension), min, max, hide_when_key, hide_when_value, show_when_key, show_when_value, choices1 (list of config_choice). For dimension: unit_cm/unit_in (min,max,step). For select: unit_label (e.g. inches).
      - hide_when: hide this option when [key] = [value]. show_when: show this option only when [key] = [value] (e.g. material = wood).
    - config_choice fields used:
      - value, label, price_type (fixed|percent), price_value, optional image (or image_url) for radio card display
      - optional conditional price: price_when_key, price_when_value, price_when_type, price_when_value_number
  {%- endcomment -%}

  {%- assign option_refs = product.metafields.custom.door_config_options.value -%}
  {%- comment -%} Applied molding pricing — paginated catalog search + direct handle lookup. {%- endcomment -%}
  {%- paginate shop.metaobjects.millwork_product_pricing.values by 250 -%}
  {%- assign _mw_pricing_catalog_all = shop.metaobjects.millwork_product_pricing.values -%}
  <script type="application/json" id="door-applied-molding-pricing-json">{
    {%- assign _am_price_first = true -%}
    {%- if option_refs != blank -%}
      {%- for opt in option_refs -%}
        {%- assign _am_opt_key = opt.key | default: opt['key'] | downcase | strip | replace: '-', '_' | replace: ' ', '_' -%}
        {%- if _am_opt_key == 'applied_molding' or _am_opt_key == 'applied_molding_choice' -%}
          {%- assign _am_choices = opt.choices1.value | default: opt.choices.value | default: opt.choices1 | default: opt.choices -%}
          {%- if _am_choices != blank -%}
            {%- for c in _am_choices -%}
              {%- assign _am_c_value = c.value | default: c['value'] | strip -%}
              {%- if _am_c_value != blank -%}
                {%- assign _am_c_lc = _am_c_value | downcase | strip -%}
                {%- assign _am_guess_hdl = '' -%}
                {%- if _am_c_lc.size >= 3 -%}
                  {%- assign _am_prefix = _am_c_lc | slice: 0, 2 -%}
                  {%- assign _am_suffix = _am_c_lc | remove: _am_prefix | strip -%}
                  {%- if _am_suffix != blank -%}
                    {%- assign _am_guess_hdl = _am_prefix | append: '-' | append: _am_suffix -%}
                  {%- endif -%}
                {%- endif -%}
                {%- assign _am_row = nil -%}
                {%- assign _am_row = shop.metaobjects.millwork_product_pricing[_am_c_lc]
                  | default: shop.metaobjects['millwork_product_pricing'][_am_c_lc]
                  | default: shop.metaobjects.millwork_product_pricing[_am_guess_hdl]
                  | default: shop.metaobjects['millwork_product_pricing'][_am_guess_hdl]
                -%}
                {%- if _am_row == blank and _mw_pricing_catalog_all != blank -%}
                  {%- for pr in _mw_pricing_catalog_all -%}
                    {%- assign _pr_sku_lc = pr.sku.value | default: pr.sku | downcase | strip -%}
                    {%- assign _pr_hdl_lc = pr.system.handle | default: pr.handle | downcase | strip -%}
                    {%- assign _pr_name_lc = pr.display_name.value | default: pr.display_name | downcase | strip -%}
                    {%- assign _pr_hdl_match = false -%}
                    {%- if _pr_sku_lc == _am_c_lc or _pr_hdl_lc == _am_c_lc or _pr_name_lc == _am_c_lc -%}
                      {%- assign _pr_hdl_match = true -%}
                    {%- elsif _am_guess_hdl != blank -%}
                      {%- if _pr_hdl_lc == _am_guess_hdl -%}
                        {%- assign _pr_hdl_match = true -%}
                      {%- elsif _pr_hdl_lc.size > _am_guess_hdl.size -%}
                        {%- assign _pr_hdl_head = _pr_hdl_lc | slice: 0, _am_guess_hdl.size -%}
                        {%- assign _pr_hdl_next = _pr_hdl_lc | slice: _am_guess_hdl.size, 1 -%}
                        {%- if _pr_hdl_head == _am_guess_hdl and _pr_hdl_next == '-' -%}
                          {%- assign _pr_hdl_match = true -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                    {%- if _pr_hdl_match -%}
                      {%- assign _am_row = pr -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                {%- if _am_row != blank -%}
                  {%- unless _am_price_first -%},{%- endunless -%}
                  {%- assign _am_price_first = false -%}
                  {{ _am_c_lc | json }}: {
                    "sku": {{ _am_row.sku.value | default: _am_row.sku | default: _am_c_value | json }},
                    "handle": {{ _am_row.system.handle | default: _am_row.handle | default: _am_c_lc | json }},
                    "display_name": {{ _am_row.display_name.value | default: _am_row.display_name | json }},
                    "wood_prices_by_tier": {% if _am_row.wood_prices_by_tier.value != blank %}{{ _am_row.wood_prices_by_tier.value | json }}{% elsif _am_row.wood_prices_by_tier != blank %}{{ _am_row.wood_prices_by_tier | json }}{% else %}{}{% endif %}
                  }
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  }</script>
  {%- endpaginate -%}
  {%- assign has_panel_unit_design_option = false -%}
  {%- if option_refs != blank -%}
    {%- for opt in option_refs -%}
      {%- assign panel_unit_key = opt.key | default: opt['key'] | downcase | strip | replace: '-', '_' -%}
      {%- if panel_unit_key == 'panel_unit_design' or panel_unit_key == 'porch_panel_project' -%}
        {%- assign has_panel_unit_design_option = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
