{%- comment -%}
Door configurator snippet for the door product page.
Usage:
- Create a snippet in your theme named 'door-configurator-snippet'
- Paste this code there.
- Include it in your door product template: {% render 'door-configurator-snippet' %}

This assumes your door product is the current product on the page.
{%- endcomment -%}

{%- comment -%}
  Add to cart uses Storefront API (no draft order). Set these so the configurator can create a cart:
  - data-storefront-api-url: Storefront GraphQL endpoint, e.g. https://{{ shop.permanent_domain }}/api/2024-01/graphql.json
  - data-storefront-access-token: Storefront API access token (from Settings > Apps and sales channels > Develop apps > Your app > API credentials > Storefront API)
  This snippet must only run on a product page. On a regular page (e.g. My saved doors) there is no product, so we show a note to use the saved_configurations template.
{%- endcomment -%} 
{%- if product -%}
  {%- comment -%}
  Storm glass metaobject routing:
  - glass_type_interior: interior-doors tag
  - glass_type_screen_and_storm: Screen And Storm Doors product type / tag
  - glass_type_exterior: all other exterior products
{%- endcomment -%}
{%- assign use_interior_glass_meta = false -%}
{%- assign use_screen_storm_glass_meta = false -%}
{%- for tag in product.tags -%}
  {%- assign t = tag | downcase | strip | replace: ' ', '-' | replace: '_', '-' -%}
  {%- if t == 'interior-doors' -%}
    {%- assign use_interior_glass_meta = true -%}
  {%- endif -%}
  {%- if t == 'screen-and-storm-doors' -%}
    {%- assign use_screen_storm_glass_meta = true -%}
  {%- endif -%}
{%- endfor -%}
{%- assign product_type_normalized_glass = product.type | default: '' | downcase | strip | replace: ' ', '_' | replace: '-', '_' -%}
{%- if product_type_normalized_glass == 'screen_and_storm_doors' -%}
  {%- assign use_screen_storm_glass_meta = true -%}
{%- endif -%}
{%- assign default_door_height_int = 82 -%}
{%- assign default_exact_door_thickness_frac = '1.75' -%}
{%- if use_screen_storm_glass_meta -%}
  {%- assign default_exact_door_thickness_frac = '1.125' -%}
{%- elsif use_interior_glass_meta -%}
  {%- assign default_exact_door_thickness_frac = '1.5' -%}
{%- endif -%}

{%- assign is_porch_panel_product = false -%}
{%- assign product_type_normalized = product.type | default: '' | downcase | strip -%}
{%- if product_type_normalized contains 'porch' -%}
  {%- assign is_porch_panel_product = true -%}
{%- endif -%}
{%- for tag in product.tags -%}
  {%- assign porch_tag = tag | downcase | strip | replace: ' ', '-' | replace: '_', '-' -%}
  {%- if porch_tag == 'porch-panel' or porch_tag == 'porch-panels' -%}
    {%- assign is_porch_panel_product = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ===== DEFAULT OPTIONS (custom.configurator_defaults metafield) - START ===== {%- endcomment -%}
{%- comment -%}
  Default selections merged from the `custom.configurator_defaults` JSON metafield,
  in priority order (earlier = wins in door-conf2.js):
    1) Product metafield  (most specific, overrides collections)
    2) Route collection   (the collection in the URL, if any)
    3) Other product.collections
  door-conf2.js applies these as pre-filled, changeable defaults after clearing.
{%- endcomment -%}
{%- capture default_selections_json -%}[
  {%- assign printed = false -%}
  {%- if product.metafields.custom.configurator_defaults != blank -%}
    {{ product.metafields.custom.configurator_defaults }}{%- assign printed = true -%}
  {%- endif -%}
  {%- if collection and collection.metafields.custom.configurator_defaults != blank -%}
    {%- if printed %},{% endif -%}{{ collection.metafields.custom.configurator_defaults }}{%- assign printed = true -%}
  {%- endif -%}
  {%- for c in product.collections -%}
    {%- if c.metafields.custom.configurator_defaults != blank and c.id != collection.id -%}
      {%- if printed %},{% endif -%}{{ c.metafields.custom.configurator_defaults }}{%- assign printed = true -%}
    {%- endif -%}
  {%- endfor -%}
]{%- endcapture -%}
{%- comment -%} ===== DEFAULT OPTIONS (custom.configurator_defaults metafield) - END ===== {%- endcomment -%}

<div id="door-configurator"
    data-base-price="{{ product.price | divided_by: 100.0 }}"
    data-product-id="{{ product.id }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-product-sku="{{ product.selected_or_first_available_variant.sku | default: '' | escape }}"
    data-product-name="{{ product.title | escape }}"
    data-storefront-api-url="https://{{ shop.permanent_domain }}/api/2026-01/graphql.json"
    data-storefront-access-token="{{ shop.metafields.custom.storefront_api_token | default: '' }}"
    data-glass-formula-api-url="{{ shop.metafields.custom.glass_formula_api_url | default: '' }}"
    data-glass-type-exterior-api-url="{{ shop.metafields.custom.glass_type_exterior_api_url | default: '' }}"
    data-glass-type-interior-api-url="{{ shop.metafields.custom.glass_type_interior_api_url | default: '' }}"
    data-glass-type-screen-and-storm-api-url="{{ shop.metafields.custom.glass_type_screen_and_storm_api_url | default: '' }}"
    data-use-interior-glass-meta="{% if use_interior_glass_meta %}true{% else %}false{% endif %}"
    data-use-screen-storm-glass-meta="{% if use_screen_storm_glass_meta %}true{% else %}false{% endif %}"
    
    data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 600 }}{% endif %}"
    data-porch-opening-preview-image="https://cdn.shopify.com/s/files/1/0784/9059/9679/files/image_109.webp?v=1778579784"
    data-product-handle="{{ product.handle }}"
    data-route-collection="{{ collection.handle | default: '' | escape }}"
    data-product-collection-handles='[{%- for c in product.collections -%}{{ c.handle | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]'
    data-product-tags='{{ product.tags | json }}'
    data-product-type="{{ product.type | default: '' | escape }}"
    {%- comment -%} ===== DEFAULT OPTIONS (custom.configurator_defaults metafield) - START ===== {%- endcomment -%}
    data-default-selections='{{ default_selections_json | strip_newlines }}'
    {%- comment -%} ===== DEFAULT OPTIONS (custom.configurator_defaults metafield) - END ===== {%- endcomment -%}
    data-complete-profile-page-url="{{ pages['complete-profile'].url | default: '/pages/complete-profile' }}"
     {% if customer %}
    {%- assign cp_zip = customer.default_address.zip | default: '' -%}
    data-customer-email="{{ customer.email }}"
    data-customer-first-name="{{ customer.first_name | escape }}"
    data-customer-last-name="{{ customer.last_name | escape }}"
    data-customer-phone="{{ customer.phone | escape }}"
    data-customer-zip="{{ cp_zip | escape }}"
    data-profile-complete="{% if customer.first_name != blank and customer.phone != blank and cp_zip != blank %}1{% else %}0{% endif %}"
    {% endif %}>

  {%- comment -%}
    Recommended hardware products (list of product references).
    Rendered inside the Hardware accordion by door-conf2.js — remove any duplicate
    "recommended products" block below the configurator in your product template.
    Each related product may define:
      - door_config_options → config_option keys (finish, function, closer_color, swing_direction, track_length, etc.)
      - product metafields → hardware_finish, hardware_function, closer_color, swing_direction, hardware_thickness_option, Door_Backset, etc.
      - door-conf2.js renders only the options present on each hardware product
  {%- endcomment -%}
  {%- assign rec_products = product.metafields.custom.recommended_products.value -%}
  {%- if rec_products != blank -%}
    <script type="application/json" id="door-recommended-hardware-products">[
      {%- for p in rec_products -%}
        {%- assign hw_finish_allow = p.metafields.custom.hardware_finish.value | default: p.metafields.custom.hardware_finish | default: '' -%}
        {%- assign hw_function_allow = p.metafields.custom.hardware_function.value | default: p.metafields.custom.hardware_function | default: '' -%}
        {%- assign hw_closer_color_allow = p.metafields.custom.closer_color.value | default: p.metafields.custom.closer_color | default: '' -%}
        {%- assign hw_swing_direction_allow = p.metafields.custom.swing_direction.value | default: p.metafields.custom.swing_direction | default: '' -%}
        {%- assign hw_track_length_allow = p.metafields.custom.door_hanger_tracker_length.value | default: p.metafields.custom.door_hanger_tracker_length | default: p.metafields.custom.track_length.value | default: p.metafields.custom.track_length | default: '' -%}
        {%- assign hw_connected_doors_allow = p.metafields.custom.number_of_connected_doors.value | default: p.metafields.custom.number_of_connected_doors | default: p.metafields.custom.connected_doors.value | default: p.metafields.custom.connected_doors | default: '' -%}
        {%- assign hw_upper_track_length_allow = p.metafields.custom.upper_track_length.value | default: p.metafields.custom.upper_track_length | default: '' -%}
        {%- assign hw_max_door_size_allow = p.metafields.custom.max_door_size.value | default: p.metafields.custom.max_door_size | default: '' -%}
        {%- assign hw_carriage_pack_type_allow = p.metafields.custom.carriage_pack_type.value | default: p.metafields.custom.carriage_pack_type | default: '' -%}
        {%- assign hw_strap_hinge_length_allow = p.metafields.custom.strap_hinge_length.value | default: p.metafields.custom.strap_hinge_length | default: '' -%}
        {%- assign hw_backset_val = p.metafields.custom.Door_Backset.value | default: p.metafields.custom.Door_Backset | default: p.metafields.custom.door_backset.value | default: p.metafields.custom.door_backset -%}
        {%- assign hw_backset_string = hw_backset_val | join: ',' -%}
        {%- if hw_backset_string == blank -%}
          {%- assign hw_backset_string = hw_backset_val | default: '' -%}
        {%- endif -%}
        {%- assign hw_thickness_val = p.metafields.custom.hardware_thickness_option.value | default: p.metafields.custom.hardware_thickness_option -%}
        {%- assign hw_thickness_string = hw_thickness_val | join: ',' -%}
        {%- if hw_thickness_string == blank -%}
          {%- assign hw_thickness_string = hw_thickness_val | default: '' -%}
        {%- endif -%}
        {%- assign hw_opts = p.metafields.custom.door_config_options.value -%}
        {%- assign hw_finish_opt = nil -%}
        {%- assign hw_function_opt = nil -%}
        {%- assign hw_closer_color_opt = nil -%}
        {%- assign hw_swing_direction_opt = nil -%}
        {%- assign hw_track_length_opt = nil -%}
        {%- assign hw_connected_doors_opt = nil -%}
        {%- assign hw_upper_track_length_opt = nil -%}
        {%- assign hw_max_door_size_opt = nil -%}
        {%- assign hw_carriage_pack_type_opt = nil -%}
        {%- assign hw_strap_hinge_length_opt = nil -%}
        {%- if hw_opts != blank -%}
          {%- for opt in hw_opts -%}
            {%- assign opt_key = opt.key | default: opt['key'] | downcase | strip -%}
            {%- if opt_key == 'finish' and hw_finish_opt == nil -%}
              {%- assign hw_finish_opt = opt -%}
            {%- elsif opt_key == 'function' and hw_function_opt == nil -%}
              {%- assign hw_function_opt = opt -%}
            {%- elsif opt_key == 'closer_color' or opt_key == 'closer-color' or opt_key == 'closer color' -%}
              {%- if hw_closer_color_opt == nil -%}
                {%- assign hw_closer_color_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'swing_direction' or opt_key == 'swing-direction' or opt_key == 'swing direction' -%}
              {%- if hw_swing_direction_opt == nil -%}
                {%- assign hw_swing_direction_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'door_hanger_tracker_length' or opt_key == 'door-hanger-tracker-length' or opt_key == 'door hanger tracker length' or opt_key == 'track_length' or opt_key == 'track-length' or opt_key == 'track length' -%}
              {%- if hw_track_length_opt == nil -%}
                {%- assign hw_track_length_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'number_of_connected_doors' or opt_key == 'number-of-connected-doors' or opt_key == 'number of connected doors' or opt_key == 'connected_doors' or opt_key == 'connected doors' -%}
              {%- if hw_connected_doors_opt == nil -%}
                {%- assign hw_connected_doors_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'upper_track_length' or opt_key == 'upper-track-length' or opt_key == 'upper track length' -%}
              {%- if hw_upper_track_length_opt == nil -%}
                {%- assign hw_upper_track_length_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'max_door_size' or opt_key == 'max-door-size' or opt_key == 'max door size' -%}
              {%- if hw_max_door_size_opt == nil -%}
                {%- assign hw_max_door_size_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'carriage_pack_type' or opt_key == 'carriage-pack-type' or opt_key == 'carriage pack type' -%}
              {%- if hw_carriage_pack_type_opt == nil -%}
                {%- assign hw_carriage_pack_type_opt = opt -%}
              {%- endif -%}
            {%- elsif opt_key == 'strap_hinge_length' or opt_key == 'strap-hinge-length' or opt_key == 'strap hinge length' -%}
              {%- if hw_strap_hinge_length_opt == nil -%}
                {%- assign hw_strap_hinge_length_opt = opt -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {
          "id": {{ p.id | json }},
          "handle": {{ p.handle | json }},
          "title": {{ p.title | json }},
          "url": {{ p.url | json }},
          "variant_id": {{ p.selected_or_first_available_variant.id | json }},
          "price_cents": {{ p.price | default: 0 }},
          "price_formatted": {{ p.price | money | json }},
          "image": {% if p.featured_image %}{{ p.featured_image | image_url: width: 480 | json }}{% else %}""{% endif %},
          "description": {{ p.description | strip_html | truncate: 120 | json }}
          ,"hardware_finish_allow": {{ hw_finish_allow | json }}
          ,"hardware_function_allow": {{ hw_function_allow | json }}
          ,"closer_color_allow": {{ hw_closer_color_allow | json }}
          ,"swing_direction_allow": {{ hw_swing_direction_allow | json }}
          ,"track_length_allow": {{ hw_track_length_allow | json }}
          ,"connected_doors_allow": {{ hw_connected_doors_allow | json }}
          ,"upper_track_length_allow": {{ hw_upper_track_length_allow | json }}
          ,"max_door_size_allow": {{ hw_max_door_size_allow | json }}
          ,"carriage_pack_type_allow": {{ hw_carriage_pack_type_allow | json }}
          ,"strap_hinge_length_allow": {{ hw_strap_hinge_length_allow | json }}
          ,"thicknessItems": {{ hw_thickness_string | split: ',' | json }}
          ,"backsetItems": {{ hw_backset_string | split: ',' | json }}
          {%- if hw_finish_opt != blank -%}
          ,"finishOption": {
            "id": {{ hw_finish_opt.key | json }},
            "label": {{ hw_finish_opt.label | default: 'Finish' | json }},
            "options": [
              {%- assign hw_choice_refs = hw_finish_opt.choices1.value | default: hw_finish_opt.choices.value -%}
              {%- if hw_choice_refs != blank -%}
                {%- for c in hw_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                    {%- assign c_img = nil -%}
                    {%- if c.image != blank -%}
                      {%- if c.image.url != blank -%}
                        {%- assign c_img = c.image.url -%}
                      {%- elsif c.image.value != blank and c.image.value.url != blank -%}
                        {%- assign c_img = c.image.value.url -%}
                      {%- elsif c.image.preview_image != blank -%}
                        {%- assign c_img = c.image.preview_image | image_url: width: 200 -%}
                      {%- elsif c.image contains 'http' or c.image contains '//' -%}
                        {%- assign c_img = c.image -%}
                      {%- endif -%}
                    {%- elsif c.image_url != blank -%}
                      {%- if c.image_url.url != blank -%}
                        {%- assign c_img = c.image_url.url -%}
                      {%- elsif c.image_url.value != blank and c.image_url.value.url != blank -%}
                        {%- assign c_img = c.image_url.value.url -%}
                      {%- elsif c.image_url.preview_image != blank -%}
                        {%- assign c_img = c.image_url.preview_image | image_url: width: 200 -%}
                      {%- else -%}
                        {%- assign c_img = c.image_url -%}
                      {%- endif -%}
                    {%- endif -%}
                    {%- if c_img != blank -%}
                    ,"image": {{ c_img | json }}
                    {%- endif -%}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_function_opt != blank -%}
          ,"functionOption": {
            "id": {{ hw_function_opt.key | json }},
            "label": {{ hw_function_opt.label | default: 'Hardware Function' | json }},
            "options": [
              {%- assign hw_fn_choice_refs = hw_function_opt.choices1.value | default: hw_function_opt.choices.value -%}
              {%- if hw_fn_choice_refs != blank -%}
                {%- for c in hw_fn_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_closer_color_opt != blank -%}
          ,"closerColorOption": {
            "id": {{ hw_closer_color_opt.key | json }},
            "label": {{ hw_closer_color_opt.label | default: 'Closer Color' | json }},
            "options": [
              {%- assign hw_cc_choice_refs = hw_closer_color_opt.choices1.value | default: hw_closer_color_opt.choices.value -%}
              {%- if hw_cc_choice_refs != blank -%}
                {%- for c in hw_cc_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_swing_direction_opt != blank -%}
          ,"swingDirectionOption": {
            "id": {{ hw_swing_direction_opt.key | json }},
            "label": {{ hw_swing_direction_opt.label | default: 'Swing Direction' | json }},
            "options": [
              {%- assign hw_sd_choice_refs = hw_swing_direction_opt.choices1.value | default: hw_swing_direction_opt.choices.value -%}
              {%- if hw_sd_choice_refs != blank -%}
                {%- for c in hw_sd_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_track_length_opt != blank -%}
          ,"trackLengthOption": {
            "id": {{ hw_track_length_opt.key | json }},
            "label": {{ hw_track_length_opt.label | default: 'Track Length' | json }},
            "options": [
              {%- assign hw_tl_choice_refs = hw_track_length_opt.choices1.value | default: hw_track_length_opt.choices.value -%}
              {%- if hw_tl_choice_refs != blank -%}
                {%- for c in hw_tl_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_connected_doors_opt != blank -%}
          ,"connectedDoorsOption": {
            "id": {{ hw_connected_doors_opt.key | json }},
            "label": {{ hw_connected_doors_opt.label | default: 'Number of Connected Doors' | json }},
            "options": [
              {%- assign hw_cd_choice_refs = hw_connected_doors_opt.choices1.value | default: hw_connected_doors_opt.choices.value -%}
              {%- if hw_cd_choice_refs != blank -%}
                {%- for c in hw_cd_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_upper_track_length_opt != blank -%}
          ,"upperTrackLengthOption": {
            "id": {{ hw_upper_track_length_opt.key | json }},
            "label": {{ hw_upper_track_length_opt.label | default: 'Upper Track Length' | json }},
            "options": [
              {%- assign hw_utl_choice_refs = hw_upper_track_length_opt.choices1.value | default: hw_upper_track_length_opt.choices.value -%}
              {%- if hw_utl_choice_refs != blank -%}
                {%- for c in hw_utl_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_max_door_size_opt != blank -%}
          ,"maxDoorSizeOption": {
            "id": {{ hw_max_door_size_opt.key | json }},
            "label": {{ hw_max_door_size_opt.label | default: 'Max Door Size' | json }},
            "options": [
              {%- assign hw_mds_choice_refs = hw_max_door_size_opt.choices1.value | default: hw_max_door_size_opt.choices.value -%}
              {%- if hw_mds_choice_refs != blank -%}
                {%- for c in hw_mds_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_carriage_pack_type_opt != blank -%}
          ,"carriagePackTypeOption": {
            "id": {{ hw_carriage_pack_type_opt.key | json }},
            "label": {{ hw_carriage_pack_type_opt.label | default: 'Carriage Pack Type' | json }},
            "options": [
              {%- assign hw_cpt_choice_refs = hw_carriage_pack_type_opt.choices1.value | default: hw_carriage_pack_type_opt.choices.value -%}
              {%- if hw_cpt_choice_refs != blank -%}
                {%- for c in hw_cpt_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
                    "label": {{ c.label | default: c.title | default: c.value | json }}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ]
          }
          {%- endif -%}
          {%- if hw_strap_hinge_length_opt != blank -%}
          ,"strapHingeLengthOption": {
            "id": {{ hw_strap_hinge_length_opt.key | json }},
            "label": {{ hw_strap_hinge_length_opt.label | default: 'Strap Hinge Length' | json }},
            "options": [
              {%- assign hw_shl_choice_refs = hw_strap_hinge_length_opt.choices1.value | default: hw_strap_hinge_length_opt.choices.value -%}
              {%- if hw_shl_choice_refs != blank -%}
                {%- for c in hw_shl_choice_refs -%}
                  {
                    "value": {{ c.value | json }},
