    {%- paginate shop.metaobjects.millwork_product_pricing.values by 250 -%}
    {%- assign _mw_pricing_catalog_all = shop.metaobjects.millwork_product_pricing.values -%}
    {%- capture schema_json -%}
      [
      {%- for opt in option_refs -%}
        {
          "id": {{ opt.key | json }},
          "label": {{ opt.label | json }},
          "type": {{ opt.input_type | downcase | strip | json }},
          {%- assign opt_desc_field = opt.description | default: opt['description'] -%}
          {%- assign opt_desc = opt_desc_field.value | default: opt_desc_field | default: '' -%}
          "description": {{ opt_desc | default: '' | json }},
          {%- if opt.min != blank -%}"min": {{ opt.min }},{%- endif -%}
          {%- if opt.max != blank -%}"max": {{ opt.max }},{%- endif -%}
          {%- assign hkey = opt.hide_when_key | default: opt['hide_when_key'] -%}
          {%- assign hval = opt.hide_when_value | default: opt['hide_when_value'] -%}
          {%- assign swkey = opt.show_when_key | default: opt['show_when_key'] -%}
          {%- assign swval = opt.show_when_value | default: opt['show_when_value'] -%}
          {%- if hkey != blank and hval != blank -%}
            "hideWhen": { {{ hkey | json }}: {{ hval | json }} },
          {%- endif -%}
          {%- if swkey != blank and swval != blank -%}
            "showWhen": { {{ swkey | json }}: {{ swval | json }} },
          {%- endif -%}
          {%- assign swpt_opt = opt.show_when_product_tags.value | default: opt.show_when_product_tags | default: opt['show_when_product_tags'] -%}
          {%- if swpt_opt != nil -%}
          ,"showWhenProductTags":{% if swpt_opt != blank %}{{ swpt_opt | json }}{% else %}[]{% endif %}
          {%- endif -%}
          {%- assign ulabel = opt.unit_label | default: opt['unit_label'] -%}
          {%- if ulabel != blank -%}
            "unit_label": {{ ulabel | json }}
          {%- endif -%}
          {%- assign opt_type_lower = opt.input_type | downcase | strip -%}
          {%- if opt_type_lower == 'dimension' -%}
            {%- assign dm_cm_min = opt.dimension_cm_min | default: opt['dimension_cm_min'] | default: 1 -%}
            {%- assign dm_cm_max = opt.dimension_cm_max | default: opt['dimension_cm_max'] | default: 140 -%}
            {%- assign dm_cm_step = opt.dimension_cm_step | default: opt['dimension_cm_step'] | default: 1 -%}
            {%- assign dm_in_min = opt.dimension_in_min | default: opt['dimension_in_min'] | default: 12 -%}
            {%- assign dm_in_max = opt.dimension_in_max | default: opt['dimension_in_max'] | default: 56 -%}
            {%- assign dm_in_step = opt.dimension_in_step | default: opt['dimension_in_step'] | default: 0.25 -%}
            "unit_cm": { "min": {{ dm_cm_min }}, "max": {{ dm_cm_max }}, "step": {{ dm_cm_step }} }
            ,"unit_in": { "min": {{ dm_in_min }}, "max": {{ dm_in_max }}, "step": {{ dm_in_step }} },
          {%- endif -%}
          "options": [
            {%- assign choice_refs = opt.choices1.value | default: opt.choices.value -%}
            {%- if choice_refs != blank -%}
              {%- for c in choice_refs -%}
                {
                  "value": {{ c.value | json }},
                  {%- assign c_label_field = c.label | default: c['label'] -%}
                  {%- assign c_title_field = c.title | default: c['title'] -%}
                  {%- assign c_display_label = c_label_field | default: c_title_field -%}
                  "label": {{ c_display_label | default: '' | json }},
                  {%- if c_title_field != blank -%}
                  "title": {{ c_title_field | json }},
                  {%- endif -%}
                  {%- assign c_desc_field = c.description | default: c['description'] -%}
                  {%- assign c_short_desc_field = c.short_description | default: c['short_description'] -%}
                  {%- assign c_subtext_field = c.subtext | default: c['subtext'] -%}
                  {%- assign c_note_field = c.note | default: c['note'] -%}
                  {%- assign c_desc = c_short_desc_field.value | default: c_short_desc_field | default: c_desc_field.value | default: c_desc_field | default: c_subtext_field.value | default: c_subtext_field | default: c_note_field.value | default: c_note_field -%}
                  "description": {{ c_desc | default: '' | json }},
                  "priceType": {{ c['price_type'] | default: c.price_type | json }},
                  "priceValue": {{ c['price_value'] | default: c.price_value | default: 0 }}
                  {%- comment -%}
                    panel_profile gating flags live on config_choice metaobjects (fields: panel_int_ext, panel_storm_panel).
                    Include them in schema_json so frontend pricing can gate panel_profile without any extra API call.
                  {%- endcomment -%}
                  {%- if opt.key == 'panel_profile' -%}
                    {%- assign _pie = c.panel_int_ext.value | default: c.panel_int_ext | default: c['panel_int_ext'] -%}
                    {%- assign _psp = c.panel_storm_panel.value | default: c.panel_storm_panel | default: c['panel_storm_panel'] -%}
                  ,"panel_int_ext": {{ _pie | default: false | json }}
                  ,"panel_storm_panel": {{ _psp | default: false | json }}
                  {%- endif -%}
                  {%- comment -%} Optional extra for slab-only pricing. {%- endcomment -%}
                  {%- if c.slab_exterior != blank -%}
                  ,"slabExterior": {{ c.slab_exterior | json }}
                  {%- endif -%}
                  {%- comment -%} Optional extra for slab-only pricing (interior products). {%- endcomment -%}
                  {%- if c.slab_interior != blank -%}
                  ,"slabInterior": {{ c.slab_interior | json }}
                  {%- endif -%}
                  {%- comment -%} Optional extra for pre-hung on jamb pricing. {%- endcomment -%}
                  {%- if c.pre_hung_exterior != blank -%}
                  ,"preHungExterior": {{ c.pre_hung_exterior | json }}
                  {%- endif -%}
                  {%- comment -%} Optional extra for pre-hung on jamb pricing (interior products). {%- endcomment -%}
                  {%- if c.pre_hung_interior != blank -%}
                  ,"preHungInterior": {{ c.pre_hung_interior | json }}
                  {%- endif -%}
                  {%- comment -%} Image: File type returns object with .url or .value.url; URL type is string. Image type may use .preview_image. {%- endcomment -%}
                  {%- assign c_img = nil -%}
                  {%- if c.image != blank -%}
                    {%- if c.image.url != blank -%}
                      {%- assign c_img = c.image.url -%}
                    {%- elsif c.image.value != blank and c.image.value.url != blank -%}
                      {%- assign c_img = c.image.value.url -%}
                    {%- elsif c.image.preview_image != blank -%}
                      {%- assign c_img = c.image.preview_image | image_url: width: 400 -%}
                    {%- elsif c.image contains 'http' or c.image contains '//' -%}
                      {%- assign c_img = c.image -%}
                    {%- endif -%}
                  {%- elsif c.image_url != blank -%}
                    {%- if c.image_url.url != blank -%}
                      {%- assign c_img = c.image_url.url -%}
                    {%- elsif c.image_url.value != blank and c.image_url.value.url != blank -%}
                      {%- assign c_img = c.image_url.value.url -%}
                    {%- elsif c.image_url.preview_image != blank -%}
                      {%- assign c_img = c.image_url.preview_image | image_url: width: 400 -%}
                    {%- else -%}
                      {%- assign c_img = c.image_url -%}
                    {%- endif -%}
                  {%- endif -%}
                  {%- if c_img != blank -%}
                  ,"image": {{ c_img | json }}
                  {%- endif -%}
                  {%- assign c_swkey = c.show_when_key.value | default: c.show_when_key | default: c['show_when_key'] -%}
                  {%- assign c_swval = c.show_when_value.value | default: c.show_when_value | default: c['show_when_value'] -%}
                  {%- assign show_list = c.show_when_list.value | default: c.show_when_list | default: c['show_when_list'] -%}
                  {%- if show_list != blank -%}
                  ,"showWhenListRaw": {{ show_list | json }}
                  {%- endif -%}
                  {%- if show_list != blank and show_list.size > 0 -%}
                  ,"showWhen": [{%- for item in show_list -%}{%- assign item_key = item.key | default: item['key'] -%}{%- assign item_val = item.value | default: item['value'] -%}{%- if item_key != blank and item_val != blank -%}{%- unless forloop.first -%},{%- endunless -%}{ {{ item_key | json }}: {{ item_val | json }} }{%- endif -%}{%- endfor -%}]
                  {%- elsif c_swkey != blank and c_swval != blank -%}
                  ,"showWhen": { {{ c_swkey | json }}: {{ c_swval | json }} }
                  {%- endif -%}
                  {%- assign c_hkey = c.hide_when_key | default: c['hide_when_key'] -%}
                  {%- assign c_hval = c.hide_when_value | default: c['hide_when_value'] -%}
                  {%- assign c_hkey2 = c.hide_when_key_2 | default: c['hide_when_key_2'] -%}
                  {%- assign c_hval2 = c.hide_when_value_2 | default: c['hide_when_value_2'] -%}
                  {%- assign hide_list = c.hide_when_list.value | default: c.hide_when_list | default: c['hide_when_list'] -%}
                  {%- if hide_list != blank and hide_list.size > 0 -%}
                  ,"hideWhen": [{%- for item in hide_list -%}{%- assign item_key = item.key | default: item['key'] -%}{%- assign item_val = item.value | default: item['value'] -%}{%- if item_key != blank and item_val != blank -%}{%- unless forloop.first -%},{%- endunless -%}{ {{ item_key | json }}: {{ item_val | json }} }{%- endif -%}{%- endfor -%}]
                  {%- elsif c_hkey != blank and c_hval != blank -%}
                  {%- if c_hkey2 != blank and c_hval2 != blank -%}
                  ,"hideWhen": [{ {{ c_hkey | json }}: {{ c_hval | json }} },{ {{ c_hkey2 | json }}: {{ c_hval2 | json }} }]
                  {%- else -%}
                  ,"hideWhen": { {{ c_hkey | json }}: {{ c_hval | json }} }
                  {%- endif -%}
                  {%- endif -%}
                  {%- comment -%} Conditional price overrides: use JSON field (unlimited) OR fixed set 1/2/3. First match wins. {%- endcomment -%}
                  {%- assign use_json_overrides = false -%}
                  {%- if c.price_overrides != blank -%}
                    {%- assign use_json_overrides = true -%}
                  {%- endif -%}
                  {%- if use_json_overrides -%}
                  {%- assign po = c.price_overrides.value | default: c.price_overrides | default: c['price_overrides'] -%}
                  ,"priceOverridesRaw":{{ po | json }}
                  {%- else -%}
                  {%- assign overrides_json = '' -%}
                  {%- assign pw1_key = c.price_when_key | default: c['price_when_key'] -%}
                  {%- assign pw1_val = c.price_when_value | default: c['price_when_value'] -%}
                  {%- if pw1_key != blank and pw1_val != blank -%}
                    {%- capture o1 -%}{"priceWhenKey":{{ pw1_key | strip | json }},"priceWhenValue":{{ pw1_val | strip | json }},"priceWhenType":{{ c.price_when_type | default: c['price_when_type'] | default: 'fixed' | strip | json }},"priceWhenValueNumber":{{ c.price_when_value_number | default: c['price_when_value_number'] | default: 0 }}}{%- endcapture -%}
                    {%- assign overrides_json = overrides_json | append: o1 -%}
                  {%- endif -%}
                  {%- assign pw2_key = c.price_when_key_2 | default: c['price_when_key_2'] -%}
                  {%- assign pw2_val = c.price_when_value_2 | default: c['price_when_value_2'] -%}
                  {%- if pw2_key != blank and pw2_val != blank -%}
                    {%- if overrides_json != '' -%}{%- assign overrides_json = overrides_json | append: ',' -%}{%- endif -%}
                    {%- capture o2 -%}{"priceWhenKey":{{ pw2_key | strip | json }},"priceWhenValue":{{ pw2_val | strip | json }},"priceWhenType":{{ c.price_when_type_2 | default: c['price_when_type_2'] | default: 'fixed' | strip | json }},"priceWhenValueNumber":{{ c.price_when_value_number_2 | default: c['price_when_value_number_2'] | default: 0 }}}{%- endcapture -%}
                    {%- assign overrides_json = overrides_json | append: o2 -%}
                  {%- endif -%}
                  {%- assign pw3_key = c.price_when_key_3 | default: c['price_when_key_3'] -%}
                  {%- assign pw3_val = c.price_when_value_3 | default: c['price_when_value_3'] -%}
                  {%- if pw3_key != blank and pw3_val != blank -%}
                    {%- if overrides_json != '' -%}{%- assign overrides_json = overrides_json | append: ',' -%}{%- endif -%}
                    {%- capture o3 -%}{"priceWhenKey":{{ pw3_key | strip | json }},"priceWhenValue":{{ pw3_val | strip | json }},"priceWhenType":{{ c.price_when_type_3 | default: c['price_when_type_3'] | default: 'fixed' | strip | json }},"priceWhenValueNumber":{{ c.price_when_value_number_3 | default: c['price_when_value_number_3'] | default: 0 }}}{%- endcapture -%}
                    {%- assign overrides_json = overrides_json | append: o3 -%}
                  {%- endif -%}
                  {%- if overrides_json != '' -%}
                  ,"priceOverrides":[{{ overrides_json }}]
                  {%- endif -%}
                  {%- endif -%}
                  {%- assign swpt = c.show_when_product_tags.value | default: c.show_when_product_tags | default: c['show_when_product_tags'] -%}
                  {%- comment -%} Output key when present so JS can hide choice until tags match. Use [] when blank so "empty = hidden until configured". {%- endcomment -%}
                  {%- if swpt != nil -%}
                  ,"showWhenProductTags":{% if swpt != blank %}{{ swpt | json }}{% else %}[]{% endif %}
                  {%- endif -%}
                  {%- assign _opt_id_lc = opt.key | default: opt['key'] | downcase | strip | replace: '-', '_' | replace: ' ', '_' -%}
                  {%- if _opt_id_lc == 'applied_molding' or _opt_id_lc == 'applied_molding_choice' -%}
                    {%- assign _c_val_lc = c.value | default: c['value'] | downcase | strip -%}
                    {%- assign _c_guess_hdl = '' -%}
                    {%- if _c_val_lc.size >= 3 -%}
                      {%- assign _c_prefix = _c_val_lc | slice: 0, 2 -%}
                      {%- assign _c_suffix = _c_val_lc | remove: _c_prefix | strip -%}
                      {%- if _c_suffix != blank -%}
                        {%- assign _c_guess_hdl = _c_prefix | append: '-' | append: _c_suffix -%}
                      {%- endif -%}
                    {%- endif -%}
                    {%- assign _am_schema_row = nil -%}
                    {%- assign _am_schema_row = shop.metaobjects.millwork_product_pricing[_c_val_lc]
                      | default: shop.metaobjects['millwork_product_pricing'][_c_val_lc]
                      | default: shop.metaobjects.millwork_product_pricing[_c_guess_hdl]
                      | default: shop.metaobjects['millwork_product_pricing'][_c_guess_hdl]
                    -%}
                    {%- if _am_schema_row == blank and _mw_pricing_catalog_all != blank -%}
                      {%- for pr in _mw_pricing_catalog_all -%}
                        {%- assign _pr_sku_lc = pr.sku.value | default: pr.sku | downcase | strip -%}
                        {%- assign _pr_hdl_lc = pr.system.handle | default: pr.handle | downcase | strip -%}
                        {%- assign _pr_name_lc = pr.display_name.value | default: pr.display_name | downcase | strip -%}
                        {%- assign _pr_schema_match = false -%}
                        {%- if _pr_sku_lc == _c_val_lc or _pr_hdl_lc == _c_val_lc or _pr_name_lc == _c_val_lc -%}
                          {%- assign _pr_schema_match = true -%}
                        {%- elsif _c_guess_hdl != blank -%}
                          {%- if _pr_hdl_lc == _c_guess_hdl -%}
                            {%- assign _pr_schema_match = true -%}
                          {%- elsif _pr_hdl_lc.size > _c_guess_hdl.size -%}
                            {%- assign _pr_schema_head = _pr_hdl_lc | slice: 0, _c_guess_hdl.size -%}
                            {%- assign _pr_schema_next = _pr_hdl_lc | slice: _c_guess_hdl.size, 1 -%}
                            {%- if _pr_schema_head == _c_guess_hdl and _pr_schema_next == '-' -%}
                              {%- assign _pr_schema_match = true -%}
                            {%- endif -%}
                          {%- endif -%}
                        {%- endif -%}
                        {%- if _pr_schema_match -%}
                          {%- assign _am_schema_row = pr -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                    {%- if _am_schema_row != blank -%}
                    ,"wood_prices_by_tier": {% if _am_schema_row.wood_prices_by_tier.value != blank %}{{ _am_schema_row.wood_prices_by_tier.value | json }}{% elsif _am_schema_row.wood_prices_by_tier != blank %}{{ _am_schema_row.wood_prices_by_tier | json }}{% else %}{}{% endif %}
                    {%- endif -%}
                  {%- endif -%}
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          ]
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
      ]
    {%- endcapture -%}
    {%- endpaginate -%}
    <script type="application/json" id="door-configurator-schema">{{ schema_json | strip_newlines | replace: '</', '<\/' }}</script>

    {%- comment -%}
      pricing_rule_int_ext records (Metaobjects).
      This prints the metaobject entries into the page so JS can read them.
      IMPORTANT: We ALWAYS render the JSON script tag (even if empty) so you can confirm presence in DOM.
      Access pattern: shop.metaobjects.<definition_handle>.values
    {%- endcomment -%}
    {%- assign _int_ext_def = shop.metaobjects.pricing_rule_int_ext | default: shop.metaobjects['pricing_rule_int_ext'] -%}
    {%- assign int_ext_rules = _int_ext_def.values -%}
    {%- capture int_ext_json -%}
      [
        {%- if int_ext_rules != blank -%}
          {%- for r in int_ext_rules -%}
            {
              "table_key": {{ r.table_key.value | default: r.table_key | default: '' | json }},
              "width_min": {{ r.width_min.value | default: r.width_min | default: 0 }},
              "width_max": {{ r.width_max.value | default: r.width_max | default: 0 }},
              "height_min": {{ r.height_min.value | default: r.height_min | default: 0 }},
              "height_max": {{ r.height_max.value | default: r.height_max | default: 0 }},
              "price": {{ r.price.value | default: r.price | default: '' | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      ]
    {%- endcapture -%}
    <script type="application/json" id="door-configurator-pricing-rule-int-ext">{{ int_ext_json | strip_newlines | replace: '</', '<\/' }}</script>
  {%- else -%}
    {%- if is_porch_panel_product -%}
      <div id="door-configurator-options" class="door-dynamic-options"></div>
      <script type="application/json" id="door-configurator-schema">[]</script>
    {%- else -%}
    <div class="door-section" style="padding:1.5rem; text-align:center; color:#6b7280;">
      <p style="margin:0;">No configuration options for this product. Add options via the product metafield <strong>door_config_options</strong> (config_option metaobjects).</p>
    </div>
    {%- endif -%}
  {%- endif -%}

  <div class="door-price-box">
    <p class="door-price-label">Estimated price</p>
    <p style="margin:0;"><span id="door-estimated-price"></span></p>
  </div>

  <div class="door-add-to-cart-wrap">
    <div class="door-actions door-actions-cart">
      <div class="millwork-form">
        <div class="millwork-cart-row select-mdiv">
          <label class="qty-label">QTY</label>
          <div class="qty-block">
            <div class="qty-wrapper">
              <button type="button" class="qty-btn minus" aria-label="Decrease quantity">-</button>
              <input type="number" id="door-config-quantity" name="quantity" min="1" max="99" value="1" inputmode="numeric" aria-label="Door quantity">
              <button type="button" class="qty-btn plus" aria-label="Increase quantity">+</button>
            </div>
          </div>
        </div>
      </div>
      <button type="button" id="door-add-to-cart-btn" class="door-btn-checkout common-btn">Add to cart</button>
      <p id="door-add-to-cart-message" class="door-inline-msg" style="display:none;"></p>
    </div>
  </div>

  <div class="door-save-config">
    <p class="door-section-title">Save configuration for later</p>
    {%- if customer -%}
    <p class="door-customer-email-logged-in">We'll save your configuration and follow up at <strong>{{ customer.email }}</strong></p>
    <p id="door-returned-from-login-note" class="door-returned-from-login-note" style="display:none; margin:0 0 0.75rem 0; padding:0.5rem 0.75rem; background:#ecfdf5; border:1px solid #a7f3d0; border-radius:6px; color:#047857; font-size:0.9rem;">You're back! Your selected options have been restored. You can save your configuration when ready.</p>
    <input id="door-customer-email" type="hidden" value="{{ customer.email }}">
    <label for="door-save-folder">Save to collection <span style="color:#dc2626;">*</span></label>
    <select id="door-save-folder" required>
      <option value="">Select a collection...</option>
      <option value="__new__">+ New collection...</option>
    </select>
    <input id="door-new-folder-name" type="text" placeholder="e.g. Kitchen project" style="display:none; margin-top:0.5rem;">
    <p id="door-saved-in-collection" class="door-saved-in-collection" style="display:none;"></p>
    <div class="config-button-div">
      <button type="button" id="door-save-config-button" class="door-btn-save common-btn btn-secondary">Save configuration</button>
      <button type="button" id="door-send-to-hubspot-button" class="door-btn-save common-btn btn-bordered secondary">Request a Callback</button>
    </div>
    <p id="door-save-config-message" style="display:none;"></p>
    <p id="door-hubspot-message" class="door-inline-msg" style="display:none;"></p>
    {%- else -%}
    {%- comment -%}
      Login → /pages/complete-profile (custom form) → back to product ?autosave=1 restores options.
    {%- endcomment -%}
    {%- assign profile_page_url = pages['complete-profile'].url | default: '/pages/complete-profile' -%}
    <p class="door-customer-email-logged-in">Please log in to save your configuration. We’ll keep your selected options while you sign in and complete a short profile.</p>
    <a class="door-btn-save common-btn" id="door-login-to-save" href="/customer_authentication/login?return_to={{ profile_page_url | strip | url_encode }}" style="display:inline-block; text-decoration:none;">Log in to save</a>
    {%- endif -%}
  </div>
    </div>
  </div>
</div>

<div class="door-porch-trim-info-modal door-hidden" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="door-porch-trim-info-title-sill">
  <div class="door-porch-trim-info-modal__backdrop" data-porch-info-close></div>
  <div class="door-porch-trim-info-modal__panel">
    <div class="door-porch-trim-info-modal__screen door-hidden" data-porch-trim-info="sill">
      <div class="door-porch-trim-info-modal_head">
        <h3 class="door-porch-trim-info-modal__title" id="door-porch-trim-info-title-sill">Sill</h3>
        <button type="button" class="door-porch-trim-info-modal__close" data-porch-info-close aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(0.703968 0.710232 -0.703968 0.710232 22.5132 0)" fill="currentColor"/> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(-0.703968 0.710232 0.703968 0.710232 1.48682 0)" fill="currentColor"/> </svg>
        </button>
      </div>
      <div class="door-porch-trim-info-modal__body mb-24">
        <p>A <strong>Sill</strong> is a solid piece of milled wood that sits beneath your Porch Enclosure Panels, tapered to shed water away from your panels and serving as a flat base for installation.
        <br/>
        <br/>
        Sills come in lengths of 8' - 12'.</p>
      </div>
      <figure class="door-porch-trim-info-modal__figure">
        <img class="door-porch-trim-info-modal__image" src="https://cdn.shopify.com/s/files/1/0784/9059/9679/files/sill_modal_image.png?v=1778585089" alt="Cross-section diagram of a mahogany sill beneath a porch panel with interior and exterior labels.">
      </figure>
    </div>

    <div class="door-porch-trim-info-modal__screen door-hidden" data-porch-trim-info="stops">
      <div class="door-porch-trim-info-modal_head">
        <h3 class="door-porch-trim-info-modal__title" id="door-porch-trim-info-title-stops">Stops</h3>
        <button type="button" class="door-porch-trim-info-modal__close" data-porch-info-close aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(0.703968 0.710232 -0.703968 0.710232 22.5132 0)" fill="currentColor"/> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(-0.703968 0.710232 0.703968 0.710232 1.48682 0)" fill="currentColor"/> </svg>
        </button>
      </div>
      <div class="door-porch-trim-info-modal__body mb-24">
        <p><strong>Stops</strong> are trim pieces that extend the length and height of your porch panels within each porch opening, securing the panels in place on the top, bottom and sides of the opening.
        <br/>
        <br/>
        Stops come in lengths of 8' - 12'.</p>
      </div>
      <figure class="door-porch-trim-info-modal__figure">
        <img class="door-porch-trim-info-modal__image" src="https://cdn.shopify.com/s/files/1/0784/9059/9679/files/Stops_modal_image.png?v=1778585089" alt="Cross-section diagram of porch panel stops on a sill with interior and exterior labels.">
      </figure>
    </div>

    <div class="door-porch-trim-info-modal__screen door-hidden" data-porch-trim-info="astragal">
      <div class="door-porch-trim-info-modal_head">
        <h3 class="door-porch-trim-info-modal__title" id="door-porch-trim-info-title-astragal">Astragal</h3>
        <button type="button" class="door-porch-trim-info-modal__close" data-porch-info-close aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(0.703968 0.710232 -0.703968 0.710232 22.5132 0)" fill="currentColor"/> <rect width="2.11202" height="31.6804" rx="1.05601" transform="matrix(-0.703968 0.710232 0.703968 0.710232 1.48682 0)" fill="currentColor"/> </svg>
        </button>
      </div>
      <div class="door-porch-trim-info-modal__body mb-24">
        <p>An <strong>Astragal</strong> is a two-piece trim unit that connects two adjacent porch panels and fills the space between them.</p>
      </div>
      <figure class="door-porch-trim-info-modal__figure">
        <img class="door-porch-trim-info-modal__image" src="https://cdn.shopify.com/s/files/1/0784/9059/9679/files/Astragal_modal_image.png?v=1778585089" alt="Cross-section diagram of an astragal connecting two porch panels to a cedar post.">
      </figure>
    </div>
  </div>
