        "display_name": {{ row.display_name.value | default: row.display_name | json }},
        "wood_prices_by_tier": {% if row.wood_prices_by_tier.value != blank %}{{ row.wood_prices_by_tier.value | json }}{% elsif row.wood_prices_by_tier != blank %}{{ row.wood_prices_by_tier | json }}{% else %}{}{% endif %}
