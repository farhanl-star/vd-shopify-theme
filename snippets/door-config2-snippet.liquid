  {%- assign _millwork_length_catalog = shop.metaobjects.millwork_length.values | default: shop.metaobjects['millwork_length'].values -%}
  {%- if _millwork_length_catalog != blank -%}
    <script type="application/json" id="door-millwork-length-catalog">[
      {%- for ml_entry in _millwork_length_catalog -%}
        {
          "id": {{ ml_entry.system.id | json }},
          "handle": {{ ml_entry.system.handle | json }},
          "value": {{ ml_entry['key'].value | default: ml_entry['key'] | json }},
          "label": {{ ml_entry['value'].value | default: ml_entry['value'] | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]</script>
  {%- endif -%}
  {%- if casing_products != blank -%}
    <script type="application/json" id="door-recommended-casing-products">[
      {%- for cp in casing_products -%}
        {%- comment -%}
          millwork_length_option → list of millwork_length metaobject refs (key + value fields).
          Nested under custom.casing product refs: resolve via | metaobject + shop.metaobjects lookup.
        {%- endcomment -%}
        {%- assign cp_full = all_products[cp.handle] | default: cp -%}
        {%- assign ml_list = cp_full.metafields.custom.millwork_length_option.value -%}
        {%- assign cp_config_mf = cp_full.metafields.custom.config_door_image -%}
        {%- if cp_config_mf == blank -%}{%- assign cp_config_mf = cp.metafields.custom.config_door_image -%}{%- endif -%}
        {%- assign cp_config_img_val = cp_config_mf.value -%}
        {%- assign cp_config_img = '' -%}
        {%- if cp_config_img_val != blank -%}
          {%- if cp_config_img_val.url != blank -%}
            {%- comment -%} generic file reference (has direct .url) {%- endcomment -%}
            {%- assign cp_config_img = cp_config_img_val.url -%}
          {%- elsif cp_config_img_val.src != blank or cp_config_img_val.width != blank -%}
            {%- comment -%} image / MediaImage object → use image_url filter {%- endcomment -%}
            {%- assign cp_config_img = cp_config_img_val | image_url: width: 520 -%}
          {%- elsif cp_config_img_val.preview_image != blank -%}
            {%- assign cp_config_img = cp_config_img_val.preview_image | image_url: width: 520 -%}
          {%- else -%}
            {%- comment -%} url / text metafield → use raw string value {%- endcomment -%}
            {%- assign cp_config_img = cp_config_img_val -%}
          {%- endif -%}
        {%- endif -%}
        {
          "id": {{ cp.id | json }},
          "handle": {{ cp.handle | json }},
          "title": {{ cp.title | json }},
          "url": {{ cp.url | json }},
          "variant_id": {{ cp.selected_or_first_available_variant.id | json }},
          "sku": {{ cp.selected_or_first_available_variant.sku | default: cp.variants.first.sku | default: '' | json }},
          "price_cents": {{ cp.price | default: 0 }},
          "price_formatted": {{ cp.price | money | json }},
          "image": {% if cp_config_img != blank %}{{ cp_config_img | json }}{% elsif cp.featured_image %}{{ cp.featured_image | image_url: width: 520 | json }}{% else %}""{% endif %}
          ,"length_handles": [
            {%- assign _ml_hdl_printed = false -%}
            {%- if ml_list != blank -%}
              {%- for lo_ref in ml_list -%}
                {%- assign lo_mo = lo_ref | metaobject | default: lo_ref -%}
                {%- assign lo_hdl = lo_mo.system.handle | default: '' | strip -%}
                {%- if lo_hdl == blank and lo_mo.system.id != blank and _millwork_length_catalog != blank -%}
                  {%- for cat_entry in _millwork_length_catalog -%}
                    {%- if cat_entry.system.id == lo_mo.system.id -%}
                      {%- assign lo_hdl = cat_entry.system.handle | strip -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                {%- if lo_hdl != blank -%}
                  {%- if _ml_hdl_printed -%},{%- endif -%}
                  {{ lo_hdl | json }}
                  {%- assign _ml_hdl_printed = true -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          ]
          ,"length_ids": [
            {%- assign _ml_id_printed = false -%}
            {%- if ml_list != blank -%}
              {%- for lo_ref in ml_list -%}
                {%- assign lo_mo = lo_ref | metaobject | default: lo_ref -%}
                {%- assign lo_id = lo_mo.system.id | default: '' -%}
                {%- if lo_id != blank -%}
                  {%- if _ml_id_printed -%},{%- endif -%}
                  {{ lo_id | json }}
                  {%- assign _ml_id_printed = true -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          ]
          ,"length_options": [
            {%- assign _ml_opt_printed = false -%}
            {%- if ml_list != blank -%}
              {%- for lo_ref in ml_list -%}
                {%- assign lo_mo = lo_ref | metaobject | default: lo_ref -%}
                {%- assign lo_hdl = lo_mo.system.handle | default: '' | strip -%}
                {%- assign mo_entry = nil -%}
                {%- if lo_hdl != blank -%}
                  {%- assign mo_entry = shop.metaobjects.millwork_length[lo_hdl] | default: shop.metaobjects['millwork_length'][lo_hdl] -%}
                {%- endif -%}
                {%- if mo_entry == blank and lo_mo.system.id != blank -%}
                  {%- for cat_entry in _millwork_length_catalog -%}
                    {%- if cat_entry.system.id == lo_mo.system.id -%}
                      {%- assign mo_entry = cat_entry -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                {%- if mo_entry != blank -%}
                  {%- assign lo_key = mo_entry['key'].value | default: mo_entry['key'] | strip -%}
                  {%- assign lo_val = mo_entry['value'].value | default: mo_entry['value'] | strip -%}
                  {%- if lo_key == 'MetaobjectListDrop' -%}{%- assign lo_key = '' -%}{%- endif -%}
                  {%- if lo_val == 'MetaobjectListDrop' -%}{%- assign lo_val = '' -%}{%- endif -%}
                  {%- if lo_key != blank or lo_val != blank -%}
                    {%- if _ml_opt_printed -%},{%- endif -%}
                    {
                      "value": {{ lo_key | default: lo_val | json }},
                      "label": {{ lo_val | default: lo_key | json }},
                      "handle": {{ mo_entry.system.handle | json }}
                    }
                    {%- assign _ml_opt_printed = true -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          ]
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]</script>
  {%- endif -%}

