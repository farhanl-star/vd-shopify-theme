{%- liquid
  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign classes = 'm-section m-collapsible-section'
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme

  assign image = section.settings.image
  assign image_position = section.settings.image_position
-%}
<style>
  #m-collapsible--{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .m-collapsible__wrapper {
    display: grid;
  }
  .m-collapsible--image-right .m-collapsible__image {
    order: 1;
  } 
  @media (min-width: 992px) {
    .m-collapsible__wrapper {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--column-gap);
      align-items: center;
    }
  }
  @media (max-width: 991.98px) {
    .m-collapsible__wrapper {
      gap: 40px;
      flex-direction:column-reverse;
      display:flex;
    }
    .m-collapsible-section{padding-bottom:0}
  } 
  @media (max-width: 767px) {
    .m-collapsible__image {
      margin-bottom: 24px;
    }
    .m-collapsible--image-right .m-collapsible__image {
      margin-bottom: 0;
      margin-top: 24px;
    }
  }
</style>
{% if section.blocks.size > 0 %}
  <section
    id="m-collapsible--{{ section.id }}"
    class="{{ classes }}"
    data-section-type="m-collapsible"
    data-section-id="{{ section.id }}"
  >
    <div class="{{ container }} m-section-my m-section-py">
      {% if image != blank %}
        <div
          class="m-collapsible__wrapper m-collapsible--image-{{ image_position }}"
          style="--column-gap: {{ section.settings.column_gap }}px;"
        >
      {% endif %}
      {% if image != blank %}
        {% liquid
          assign image_height = image.width | divided_by: image.aspect_ratio | round
        %}
        <div class="m-collapsible__image">
 {% render 'index-section-header', section_settings: section.settings %}
          {{
            image
            | image_url: width: 3840
            | image_tag:
              loading: 'lazy',
              width: image.width,
              height: image_height,
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500',
              alt: image.alt
            | escape
          }}
        </div>
      {% endif %}
      {% if image != blank %}<div class="m-collapsible__content-wrapper">{% endif %}
     
      <div class="m-collapsible-section__wrapper{% if template == 'product' %} m-product-collapsible{% endif %}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
        {% for block in section.blocks %}
          <collapsible-tab
            class="m-collapsible no-js-hidden"
            data-block-id="collapsible-tab-{{ block.id }}"
            {% if block.settings.open %}
              open="true"
            {% endif %}
          >
            <h3 class="m-collapsible--button {{ block.settings.text_size }}" data-trigger>
              <span>{{ block.settings.header }}</span>
              <span class="m-collapsible--icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none"> 
                <rect x="7" width="2" height="16" rx="1" fill="#00476C"/> 
                <rect x="16" y="7" width="2" height="16" rx="1" transform="rotate(90 16 7)" fill="#00476C" class="vertical"> </svg>
              </span>
            </h3>
            <div class="m-collapsible--content" data-content hidden>
              <div class="m-collapsible--content__inner">
                {% case block.type %}
                  {% when 'item' %}
                    <div class="rte">
                      {{ block.settings.content }}
                      {{ block.settings.content_page.content }}
                    </div>
                  {% when 'liquid' %}
                    {{ block.settings.custom_liquid }}
                  {% else %}

                {% endcase %}
              </div>
            </div>
          </collapsible-tab>
        {% endfor %}
      </div>
      {% if image != blank %}</div>{% endif %}
      {% if image != blank %}</div>{% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Collapsible tabs",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Fixed width"
        },
        {
          "value": "container-fluid",
          "label": "Stretched width"
        },
        {
          "value": "container-narrow",
          "label": "Narrow width"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 100
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h5",
      "options": [
        {
          "label": "Medium",
          "value": "h5"
        },
        {
          "label": "Large",
          "value": "h2"
        }
      ]
    },
    {
      "type": "html",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Animations"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Visible in the view animation",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Inherit global setting"
        },
        {
          "value": "fade-in",
          "label": "Fade in"
        },
        {
          "value": "fade-in-up",
          "label": "Fade in up"
        },
        {
          "value": "fade-in-left",
          "label": "Fade in left"
        },
        {
          "value": "fade-in-right",
          "label": "Fade in right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Custom Attributes"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom classes"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Custom content",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "label": "Collapsible tab",
          "default": "Collapsible tab heading"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Text size",
          "options": [
            {
              "value": "h5",
              "label": "Small"
            },
            {
              "value": "h4",
              "label": "Medium"
            },
            {
              "value": "h3",
              "label": "Large"
            }
          ]
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Accordion content",
          "default": "<p>Shipping cost is based on weight. Just add products to your cart and use the Shipping Calculator to see the shipping price.</p><p>We want you to be 100% satisfied with your purchase. Items can be returned or exchanged within 30 days of delivery.</p>"
        },
        {
          "type": "page",
          "id": "content_page",
          "label": "Tab content from page"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "Default open"
        }
      ]
    },
    {
      "type": "liquid",
      "name": "Custom liquid",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "label": "Tab heading",
          "default": "Tab heading"
        },
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom liquid"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible tabs",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
