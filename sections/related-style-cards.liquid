
{% assign related_count = 0 %}

{% for gid in collection.metafields.custom.related_collection.value %}
  {% assign related_collection = gid %}

  {% if related_collection and related_collection.id != collection.id %}
    {% assign related_count = related_count | plus: 1 %}
  {% endif %}

  {% if related_count >= 1 %}
    {% break %}
  {% endif %}
{% endfor %}

{% if related_count > 0 %}
<section class="related-styles-section">
  <div class="related-styles-container container">
    {% if section.settings.heading != blank %}
      <h5 class="related-styles-heading">{{ section.settings.heading }}</h5>

    {% endif %}

      {% if section.settings.sub_heading != blank %}
      <p class="related-styles-sub-heading">{{ section.settings.sub_heading }}</p>

    {% endif %}

    <div class="related-styles-grid">
{% assign count = 0 %}
{% for gid in collection.metafields.custom.related_collection.value %}
 {% if count == 3 %}
    {% break %}
  {% endif %}

  {% assign related_collection = gid  %}

  {% if related_collection and related_collection.id != collection.id%}
    <a class="related-style-card" href="{{ related_collection.url }}">

      <div class="related-style-image">
        {% if related_collection.image %}
          <img src="{{ related_collection.image | img_url: '600x' }}" alt="{{ related_collection.title }}">
        {% else %}
          <div class="placeholder">No Image</div>
        {% endif %}
      </div>

      <h3 class="related-style-title">
        {{ related_collection.title }}
      </h3>

    </a>
      {% assign count = count | plus: 1 %}
  {% endif %}

{% endfor %}


  

</div>

  </div>
</section>
{% endif %}


{% schema %}
{
  "name": "Related Style Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Explore Other Styles"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Explore Other Styles"
    }
  ],
 
  "presets": [
    {
      "name": "Related Style Cards"
    }
  ]
}
{% endschema %}

<style>

.related-styles-section {padding: 80px 0;}
.related-styles-heading {font-weight: 400;text-align: center;color:var(--sootBlackColor);margin-bottom:8px;}
.related-styles-grid {display: flex;justify-content:center;flex-wrap:wrap;gap: 64px;margin-top:48px;}
.related-style-card {background: #fff;border-radius: 8px;overflow: hidden;text-decoration: none;color: inherit;transition: transform 0.2s ease;border: 1px solid #e5e5e5;width:calc(20% - 52px)}
.related-style-card:hover {transform: translateY(-5px);}
.related-style-image img {width: 100%;height: 260px;object-fit: cover;}
.related-style-title {padding: 15px;font-size: 18px;font-weight: 600;}
.related-styles-sub-heading{font-weight: 400;font-size: 20px;line-height: 150%;letter-spacing: 0;text-align: center;vertical-align: middle;color:var(--sootBlackColor)}

.placeholder {background: #ddd;height: 260px;display: flex;align-items: center;justify-content: center;}
@media (max-width: 991.98px) {
    .related-styles-sub-heading{font-size: 16px;line-height: 135%;}
    .related-styles-section{padding-block:60px;}
}
</style>
