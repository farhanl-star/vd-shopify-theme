<section class="how-it-works py-80">
  <div class="container">

    <!-- Header -->
    <div class="how-it-works__header common-center-div mb-40">
      {% if section.settings.icon %}
        <img
          src="{{ section.settings.icon | image_url: width: 120 }}"
          alt="Icon"
          class="how-it-works__icon"
        >
      {% endif %}

      <h4 class="how-it-works__title">
        {{ section.settings.heading }}
      </h4>

      <p class="how-it-works__subtitle common-header-desc">
        {{ section.settings.subheading }}
      </p>
    </div>

    <!-- Steps -->
    <div class="how-it-works__steps">
      {% for block in section.blocks %}
        <div class="how-it-works__step" {{ block.shopify_attributes }}>

          <span class="how-it-works__number">
            {{ forloop.index }}
          </span>
          <div>
            <h3 class="how-it-works__step-title">
              {{ block.settings.title }}
            </h3>

            <p class="how-it-works__step-text">
              {{ block.settings.text }}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- CTA -->
    {% if section.settings.button_label %}
      <div class="how-it-works__cta pt-60">
        <a
          href="{{  product.url | within: collection }}"
          class="button button--primary common-btn"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Top icon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Here’s How It Works"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Custom-made, easy to order, and built to last"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Customize Your Door"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
