<section class="additional-products pt-60 pb-80">
  <div class="page-width container">

    {% if section.settings.heading != blank %}
      <h6 class="additional-products__title">
        {{ section.settings.heading }}
      </h6>
    {% endif %}

    <div class="additional-products__grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        {% if collection != blank %}
          <div class="additional-products__item">
            <a href="{{ collection.url }}" class="additional-products__link">
    
{% assign collection = collections[block.settings.collection] %}

{% if block.settings.custom_image %}
  <img
    src="{{ block.settings.custom_image | image_url: width: 600 }}"
    alt="{{ collection.title | escape }}"
    loading="lazy"
  >
{% elsif collection.image %}
  <img
    src="{{ collection.image | image_url: width: 600 }}"
    alt="{{ collection.title | escape }}"
    loading="lazy"
  >
{% endif %}

            </a>

            <h3 class="additional-products__name">
              {{ collection.title }}
            </h3>

            <a href="{{ collection.url }}" class="additional-products__cta common-btn common-link secondary">
              View the doors
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Additional Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Additional Products"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        },
         {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image (optional)"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Additional Products"
    }
  ]
}
{% endschema %}
