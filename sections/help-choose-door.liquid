<section class="help-choose-door-section fade-section" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <style>
    .help-choose-container {
      width:100%;
      margin: 0 auto;
      background: {{ section.settings.box_color }};
      color: {{ section.settings.box_text_color }};
      border-radius: 12px;
      text-align: center;
      padding-inline:20px;
    }

    .help-choose-container .help-choose-header { max-width: 640px; margin-bottom:8px; text-align:center; margin-inline:auto; }
    .help-buttons{display:flex;align-items:center;justify-content:center;gap:24px;}
    .help-choose-container p.subheading { max-width: 640px; margin: 0 auto 24px auto; color:var(--silkWhiteColor) }

    /* Fade effect */
    .fade-section {
      opacity: 0;
      transform: translateY(25px);
      transition: opacity 600ms cubic-bezier(0, 0, 0.3, 1), 
                  transform 600ms cubic-bezier(0, 0, 0.3, 1);
    }
    .fade-section.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
  <div class=" container pb-80">
    <div class="help-choose-container py-80">
      <h5 class="help-choose-header primaryFont text-white">{{ section.settings.heading }}</h5>

      <p class="subheading">
        {{ section.settings.subheading }}
      </p>

      <div class="help-buttons">
        {% if section.settings.btn1_text != blank %}
        <a href="{{ section.settings.btn1_link }}" class="common-btn btn-white btn-large">
          {{ section.settings.btn1_text }} 
          <svg class="btn-1" xmlns="http://www.w3.org/2000/svg" width="8" height="14" viewBox="0 0 8 14" fill="none"> <path d="M1 1L7 7L1 13" stroke="#002031" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/> </svg>
        </a>
        {% endif %}

        {% if section.settings.btn2_text != blank %}
        <a href="{{ section.settings.btn2_link }}" class="common-btn btn-white btn-bordered btn-large">
          {{ section.settings.btn2_text }} 
          <svg class="btn-2" xmlns="http://www.w3.org/2000/svg" width="11" height="13" viewBox="0 0 11 13" fill="none"> <path d="M0.5 9V12H10.5V9" stroke="#FDFEFF" stroke-linecap="round"/> <path d="M5.5 0.5L5.5 7.5" stroke="#FDFEFF" stroke-linecap="round"/> <path d="M9.5 4L5.5 8L1.5 4" stroke="#FDFEFF" stroke-linecap="round" stroke-linejoin="round"/> </svg>
        </a>
        {% endif %}
      </div>
    </div>
  </div>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const elements = document.querySelectorAll(".fade-section");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
          }
        });
      }, { threshold: 0.2 });

      elements.forEach(el => observer.observe(el));
    });
  </script>
</section>

{% schema %}
{
  "name": "Help Choose Door Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#0b2a38"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "box_color",
      "label": "Box Background",
      "default": "#002233"
    },
    {
      "type": "color",
      "id": "box_text_color",
      "label": "Box Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need help choosing the right door?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether you've got a tape measure in hand or just a photo and a feeling, we'll help you figure out what fits—in style and size."
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Primary Button Text",
      "default": "Take the Fit Finder Quiz →"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Secondary Button Text",
      "default": "Download the Measuring Guide ⬇"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 5,
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 5,
      "label": "Bottom Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_sides",
      "min": 10,
      "max": 80,
      "step": 5,
      "label": "Side Padding",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Help Choose Door Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
