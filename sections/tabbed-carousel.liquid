<style>
  
  /* Layout */
  .tabbed-carousel-section .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  /* Left image */
  .tabbed-carousel-section .left-image{width:100%;height:100%;}
  .tabbed-carousel-section .left-image img {
    width: 100%;
    display: block;
    height:auto;
    object-fit:contain;
  }

  /* Tabs */
  .tabbed-carousel-section .tabs {
    display: flex;
    border-bottom: 1px solid var(--secondary400Color);
    margin-bottom: 24px;
    position: relative;
    justify-content:center;
    z-index: 10;
  }

  .tabbed-carousel-section .tab-btn {
    background: none;
    padding: 8px 40px;
    cursor: pointer;
    font-weight: 600;
    font-size: 18px;
    line-height: 150%;
    letter-spacing: 0;
    color:var(--secondary400Color);
    border-bottom: 5px solid #0000;
  }

  .tabbed-carousel-section .tab-btn.active {
    border-bottom-color:var(--secondary400Color);
  }

  /* Tab content */
  .tabbed-carousel-section .tab-content {
    display: none;
  }

  .tabbed-carousel-section .tab-content.active {
    display: block;
  }
  .tabbed-carousel-section .tabs-wrapper {
    margin-top: 24px;
    overflow: visible;
  }
  .tabbed-carousel-section .content {
    overflow: visible;
    min-width: 0;
  }

  /* Block carousel (whole block = title + desc + image) */
  .tabbed-carousel-section .block-carousel {
    overflow: hidden;
    position: relative;
  }

  .tabbed-carousel-section .block-carousel-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .tabbed-carousel-section .slide-block {
    min-width: 0;
    flex-shrink: 0;
    overflow: visible;
    box-sizing: border-box;
  }

  .tabbed-carousel-section .carousel-img-div { position: relative; height: 225px; }
  .tabbed-carousel-section .carousel-img-div img { position: absolute; top: 0; left: 0; height: 100%; width: 100%; object-fit: cover; }

  /* Navigation */
  .tabbed-carousel-section .carousel-nav {
    display: flex;
    gap: 24px;
    bottom: 30px;
    position:absolute;
  }

  .tab-inner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    min-width: 0;
  }
  .tabbed-carousel-section .tab-inner-content {
    min-width: 0;
    overflow: visible;
  }
  .tab-inner-title { font-weight: 600; font-size: 20px; line-height: 150%; letter-spacing: 0; margin-bottom: 8px; overflow: visible; }
  .tab-inner-desc { font-weight: 400; font-size: 16px; line-height: 150%; letter-spacing: 0; overflow: visible; }
  @media (max-width: 991.98px) {
      .tabbed-carousel-section .grid{grid-template-columns: 1fr;gap:64px}
  }
  @media (max-width: 767.98px) {
    .tabbed-carousel-section .tab-btn{padding:8px 20px;min-width:fit-content;overflow: auto;justify-content: start;}
    .tabbed-carousel-section .tabs{margin-bottom:40px;}
  }
  @media (max-width: 576px) {
    .tab-inner-grid{grid-template-columns: 1fr;}
    .tabbed-carousel-section .tab-inner-content{order:10}
    .tabbed-carousel-section .carousel-nav{margin-top: 32px;position: static;}
  }

</style>
<section class="tabbed-carousel-section py-120"   data-section-id="{{ section.id }}">
  <div class="page-width container">
    <div class="grid">
      <div class="left-image">
        {% if section.settings.left_image %}
          <img
            src="{{ section.settings.left_image | image_url: width: 1000 }}"
            alt="image"
            loading="lazy">
        {% endif %}
      </div>

      <!-- LEFT CONTENT -->
      <div class="content">
        <h5 class="mb-8">{{ section.settings.heading }}</h5>
        <p class="p-large mb-24 headingFont">{{ section.settings.subHeading }}</p>
        <div class="rte">{{ section.settings.description }}</div>
        <div class="tabs-wrapper">
        
          <!-- TABS -->
          <div class="tabs">
            {% for block in section.blocks %}
              {% if block.type == 'tab' %}
                <button
                  class="tab-btn {% if forloop.first %}active{% endif %}"
                  data-tab-target="tab-{{ block.id }}">
                  {{ block.settings.tab_title }}
                </button>
              {% endif %}
            {% endfor %}
          </div>

          <!-- TAB CONTENT -->
          {% for block in section.blocks %}
            {% if block.type == 'tab' %}
              <div
                class="tab-content {% if forloop.first %}active{% endif %}"
                id="tab-{{ block.id }}"
                {{ block.shopify_attributes }}>
                <div class="block-carousel">
                  <div class="block-carousel-track">
                    {% comment %} Slide 1 - show if has title, text, or image {% endcomment %}
                    {% if block.settings.slide_title != blank or block.settings.slide_text != blank or block.settings.image_1 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_1 %}<img src="{{ block.settings.image_1 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                    {% comment %} Slide 2 {% endcomment %}
                    {% if block.settings.slide_title_2 != blank or block.settings.slide_text_2 != blank or block.settings.image_2 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title_2 }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text_2 }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_2 %}<img src="{{ block.settings.image_2 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                    {% comment %} Slide 3 {% endcomment %}
                    {% if block.settings.slide_title_3 != blank or block.settings.slide_text_3 != blank or block.settings.image_3 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title_3 }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text_3 }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_3 %}<img src="{{ block.settings.image_3 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                    {% comment %} Slide 4 {% endcomment %}
                    {% if block.settings.slide_title_4 != blank or block.settings.slide_text_4 != blank or block.settings.image_4 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title_4 }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text_4 }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_4 %}<img src="{{ block.settings.image_4 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                    {% comment %} Slide 5 {% endcomment %}
                    {% if block.settings.slide_title_5 != blank or block.settings.slide_text_5 != blank or block.settings.image_5 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title_5 }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text_5 }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_5 %}<img src="{{ block.settings.image_5 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                    {% comment %} Slide 6 {% endcomment %}
                    {% if block.settings.slide_title_6 != blank or block.settings.slide_text_6 != blank or block.settings.image_6 %}
                      <div class="slide-block">
                        <div class="tab-inner-grid">
                          <div class="tab-inner-content">
                            <p class="tab-inner-title">{{ block.settings.slide_title_6 }}</p>
                            <p class="tab-inner-desc">{{ block.settings.slide_text_6 }}</p>
                          </div>
                          <div class="carousel-img-div">
                            {% if block.settings.image_6 %}<img src="{{ block.settings.image_6 | image_url: width: 700 }}" alt="" loading="lazy">{% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                  <div class="carousel-nav">
                    <button class="block-prev" type="button">
                      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="21" viewBox="0 0 26 21" fill="none">
                        <path d="M9.37109 2.51562L1.13229 11.3037L9.37087 20.0918" stroke="#806730"/>
                        <rect width="25" height="1" transform="matrix(-1 0 0 1 26 10.7695)" fill="#806730"/>
                      </svg>
                    </button>
                    <button class="block-next" type="button">
                      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="21" viewBox="0 0 26 21" fill="none">
                        <path d="M16.6289 2.51562L24.8677 11.3037L16.6291 20.0918" stroke="#806730"/>
                        <rect y="10.7695" width="25" height="1" fill="#806730"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector(
      '.tabbed-carousel-section[data-section-id="{{ section.id }}"]'
    );
    if (!section) return;

    /* -------- BLOCK CAROUSEL: arrows change whole block (title + desc + image) per tab -------- */
    section.querySelectorAll('.tab-content .block-carousel').forEach((blockCarousel) => {
      initBlockCarousel(blockCarousel);
    });

    function initBlockCarousel(blockCarousel) {
      const track = blockCarousel.querySelector('.block-carousel-track');
      const slideBlocks = blockCarousel.querySelectorAll('.slide-block');
      const prev = blockCarousel.querySelector('.block-prev');
      const next = blockCarousel.querySelector('.block-next');

      if (!track || slideBlocks.length === 0) return;

      let index = 0;
      const total = slideBlocks.length;

      function getSlideWidth() {
        return blockCarousel.offsetWidth;
      }

      function applySizes() {
        const carouselWidth = getSlideWidth();
        if (carouselWidth <= 0) return;
        track.style.display = 'flex';
        track.style.transition = 'transform 0.4s ease';
        track.style.width = (total * carouselWidth) + 'px';

        slideBlocks.forEach((slide) => {
          slide.style.flexBasis = carouselWidth + 'px';
          slide.style.maxWidth = carouselWidth + 'px';
          slide.style.minWidth = carouselWidth + 'px';
        });
        update();
      }

      function update() {
        const slideWidth = getSlideWidth();
        if (slideWidth <= 0) return;
        const offset = index * slideWidth;
        track.style.transform = 'translateX(-' + offset + 'px)';
      }

      next?.addEventListener('click', () => {
        index = (index + 1) % total;
        update();
      });

      prev?.addEventListener('click', () => {
        index = (index - 1 + total) % total;
        update();
      });

      blockCarousel._carouselRefresh = applySizes;
      applySizes();
      window.addEventListener('resize', applySizes);
    }

    /* ---------------- TABS: refresh carousel when tab becomes active (was hidden, had 0 width) ---------------- */
    const tabButtons = section.querySelectorAll('[data-tab-target]');
    const tabContents = section.querySelectorAll('.tab-content');

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.tabTarget;

        tabButtons.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        btn.classList.add('active');
        const activeContent = section.querySelector('#' + targetId);
        if (activeContent) activeContent.classList.add('active');

        const activeCarousel = activeContent?.querySelector('.block-carousel');
        if (activeCarousel && typeof activeCarousel._carouselRefresh === 'function') {
          requestAnimationFrame(() => activeCarousel._carouselRefresh());
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Tabbed Carousel Section",
  "settings": [
     {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left side image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Screen and Glass Inserts"
    },
    {
      "type": "text",
      "id": "subHeading",
      "label": "Sub Heading",
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Carousel Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab label"
        },
        {
          "type": "text",
          "id": "slide_title",
          "label": "Slide title"
        },
        {
          "type": "textarea",
          "id": "slide_text",
          "label": "Slide 1 description"
        },
        { "type": "text", "id": "slide_title_2", "label": "Slide 2 title" },
        { "type": "textarea", "id": "slide_text_2", "label": "Slide 2 description" },
        { "type": "text", "id": "slide_title_3", "label": "Slide 3 title" },
        { "type": "textarea", "id": "slide_text_3", "label": "Slide 3 description" },
        { "type": "text", "id": "slide_title_4", "label": "Slide 4 title" },
        { "type": "textarea", "id": "slide_text_4", "label": "Slide 4 description" },
        { "type": "text", "id": "slide_title_5", "label": "Slide 5 title" },
        { "type": "textarea", "id": "slide_text_5", "label": "Slide 5 description" },
        { "type": "text", "id": "slide_title_6", "label": "Slide 6 title" },
        { "type": "textarea", "id": "slide_text_6", "label": "Slide 6 description" },

        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "image_picker", "id": "image_4", "label": "Image 4" },
        { "type": "image_picker", "id": "image_5", "label": "Image 5" },
        { "type": "image_picker", "id": "image_6", "label": "Image 6" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed Carousel"
    }
  ]
}
{% endschema %}
