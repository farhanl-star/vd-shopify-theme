<script>
  document.querySelectorAll('.door-setup-collapsible').forEach((el) => {
    const btn = el.querySelector('.door-setup-collapsible--button');
    const content = el.querySelector('.door-setup-collapsible--content');

    btn.addEventListener('click', (e) => {
      e.preventDefault(); // IMPORTANT: stop default <details> toggle

      const isOpen = el.classList.contains('is-expanded');

      // Close all
      document.querySelectorAll('.door-setup-collapsible').forEach((item) => {
        const c = item.querySelector('.door-setup-collapsible--content');

        // set current height first (fix for smooth closing)
        c.style.maxHeight = c.scrollHeight + 'px';

        // force reflow
        c.offsetHeight;

        item.classList.remove('is-expanded');
        c.style.maxHeight = '0px';
      });

      if (!isOpen) {
        el.classList.add('is-expanded');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });
  });
  document.querySelectorAll('.door-setup-collapsible').forEach((el) => {
    const btn = el.querySelector('.door-setup-collapsible--button');

    btn.addEventListener('click', () => {
      const isOpen = el.getAttribute('open') === 'true';

      // close all (optional)
      document.querySelectorAll('.door-setup-collapsible').forEach((item) => {
        item.setAttribute('open', 'false');
      });

      // toggle current
      el.setAttribute('open', isOpen ? 'false' : 'true');
    });
  });
</script>
