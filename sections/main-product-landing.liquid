              window.__landingHardwareFirstSwingDirectionLabel = {{ hw_first_swing_direction_label | json }};
              window.__landingHardwareFirstBackset = {{ hw_first_backset_value | json }};
              window.__landingHardwareFirstBacksetLabel = {{ hw_first_backset_label | json }};
              window.__landingHardwareFirstTrackLength = {{ hw_first_track_length_value | json }};
              window.__landingHardwareFirstTrackLengthLabel = {{ hw_first_track_length_label | json }};
              window.__landingHardwareFirstConnectedDoors = {{ hw_first_connected_doors_value | json }};
              window.__landingHardwareFirstConnectedDoorsLabel = {{ hw_first_connected_doors_label | json }};
              window.__landingHardwareFirstUpperTrackLength = {{ hw_first_upper_track_length_value | json }};
              window.__landingHardwareFirstUpperTrackLengthLabel = {{ hw_first_upper_track_length_label | json }};
              window.__landingHardwareFirstMaxDoorSize = {{ hw_first_max_door_size_value | json }};
              window.__landingHardwareFirstMaxDoorSizeLabel = {{ hw_first_max_door_size_label | json }};
              window.__landingHardwareFirstCarriagePackType = {{ hw_first_carriage_pack_type_value | json }};
              window.__landingHardwareFirstCarriagePackTypeLabel = {{ hw_first_carriage_pack_type_label | json }};
              window.__landingHardwareFirstStrapHingeLength = {{ hw_first_strap_hinge_length_value | json }};
              window.__landingHardwareFirstStrapHingeLengthLabel = {{ hw_first_strap_hinge_length_label | json }};

              (function () {
                function ensurePropertyInput(form, key, value) {
                  if (!form) return;
                  var name = 'properties[' + key + ']';
                  var el = form.querySelector('input[name="' + name + '"]');
                  if (!el) {
                    el = document.createElement('input');
                    el.type = 'hidden';
                    el.name = name;
                    form.appendChild(el);
                  }
                  el.value = String(value == null ? '' : value);
                }

                function initLandingHardwareSwatches() {
                  var root = document.querySelector('[data-landing-hardware-config="1"]');
                  if (!root || root.getAttribute('data-hw-swatch-init') === '1') return;

                  var card = root.querySelector('.door-suggested-hardware-card');
                  if (!card) return;

