            <script>
              window.__landingHardwareDefaults = {% if product.metafields.custom.hardware_default_selection != blank %}{{ product.metafields.custom.hardware_default_selection.value | default: product.metafields.custom.hardware_default_selection | json }}{% else %}null{% endif %};

              (function () {
                var defaults = window.__landingHardwareDefaults;
                if (typeof defaults === 'string') {
                  try { defaults = JSON.parse(defaults); } catch (e) { defaults = null; }
                }
                if (!defaults || typeof defaults !== 'object') return;

                function norm(s) {
                  return String(s == null ? '' : s)
                    .toLowerCase()
                    .replace(/[\u2018\u2019\u201c\u201d'"]/g, '')
                    .replace(/[^a-z0-9]+/g, '_')
                    .replace(/^_+|_+$/g, '');
                }

                function getDesired(keys) {
                  for (var i = 0; i < keys.length; i++) {
                    var k = keys[i];
                    if (Object.prototype.hasOwnProperty.call(defaults, k)) {
                      var v = defaults[k];
                      if (v != null && String(v).trim() !== '') return String(v);
                    }
                  }
                  return null;
                }

                var SELECT_FIELDS = [
                  { keys: ['hardware_function', 'door_config_options.function', 'function'], sel: 'select.door-suggested-hardware-function, select[data-hw-function-select]', valueAttr: 'data-hw-function-value', labelAttr: 'data-hw-function-label', prop: 'Hardware Function' },
                  { keys: ['door_config_options.closer_color', 'closer_color', 'hardware_closer_color'], sel: 'select.door-suggested-hardware-closer-color, select[data-hw-closer-color-select]', valueAttr: 'data-hw-closer-color-value', labelAttr: 'data-hw-closer-color-label', prop: 'Closer Color' },
                  { keys: ['hardware_thickness_option', 'door_config_options.hardware_thickness_option', 'thickness'], sel: 'select.door-suggested-hardware-thickness, select[data-hw-thickness-select]', valueAttr: 'data-hw-thickness-value', labelAttr: 'data-hw-thickness-label', prop: 'Door Thickness' },
                  { keys: ['door_config_options.swing_direction', 'swing_direction'], sel: 'select.door-suggested-hardware-swing-direction, select[data-hw-swing-direction-select]', valueAttr: 'data-hw-swing-direction-value', labelAttr: 'data-hw-swing-direction-label', prop: 'Swing Direction' },
                  { keys: ['hardware_backset', 'door_config_options.door_backset', 'door_backset', 'backset'], sel: 'select.door-suggested-hardware-backset, select[data-hw-backset-select]', valueAttr: 'data-hw-backset-value', labelAttr: 'data-hw-backset-label', prop: 'Door Backset' },
                  { keys: ['door_config_options.door_hanger_tracker_length', 'door_hanger_tracker_length', 'track_length'], sel: 'select.door-suggested-hardware-track-length, select[data-hw-track-length-select]', valueAttr: 'data-hw-track-length-value', labelAttr: 'data-hw-track-length-label', prop: 'Track Length' },
                  { keys: ['door_config_options.number_of_connected_doors', 'number_of_connected_doors', 'connected_doors'], sel: 'select.door-suggested-hardware-connected-doors, select[data-hw-connected-doors-select]', valueAttr: 'data-hw-connected-doors-value', labelAttr: 'data-hw-connected-doors-label', prop: 'Number of Connected Doors' },
                  { keys: ['door_config_options.upper_track_length', 'upper_track_length'], sel: 'select.door-suggested-hardware-upper-track-length, select[data-hw-upper-track-length-select]', valueAttr: 'data-hw-upper-track-length-value', labelAttr: 'data-hw-upper-track-length-label', prop: 'Upper Track Length' },
                  { keys: ['door_config_options.max_door_size', 'max_door_size'], sel: 'select.door-suggested-hardware-max-door-size, select[data-hw-max-door-size-select]', valueAttr: 'data-hw-max-door-size-value', labelAttr: 'data-hw-max-door-size-label', prop: 'Max Door Size' },
                  { keys: ['door_config_options.carriage_pack_type', 'carriage_pack_type'], sel: 'select.door-suggested-hardware-carriage-pack-type, select[data-hw-carriage-pack-type-select]', valueAttr: 'data-hw-carriage-pack-type-value', labelAttr: 'data-hw-carriage-pack-type-label', prop: 'Carriage Pack Type' },
                  { keys: ['hardware_strap_hinge_length', 'door_config_options.strap_hinge_length', 'strap_hinge_length'], sel: 'select.door-suggested-hardware-strap-hinge-length, select[data-hw-strap-hinge-length-select]', valueAttr: 'data-hw-strap-hinge-length-value', labelAttr: 'data-hw-strap-hinge-length-label', prop: 'Strap Hinge Length' }
                ];

                function dispatchChange(el) {
                  try {
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                  } catch (e) {
                    try {
                      var ev = document.createEvent('HTMLEvents');
                      ev.initEvent('change', true, false);
                      el.dispatchEvent(ev);
                    } catch (e2) {}
                  }
                }

                function clearProperty(prop) {
                  if (!prop) return;
                  var name = 'properties[' + prop + ']';
                  Array.prototype.forEach.call(document.querySelectorAll('form.millwork-form input[name="' + name + '"]'), function (input) {
                    input.value = '';
                  });
                }

                function applySelect(card, def) {
                  var desired = getDesired(def.keys);
                  if (desired == null) return;
                  var sel = card.querySelector(def.sel);
                  if (!sel || !sel.options) return;
                  var dn = norm(desired);
                  var match = null;
                  for (var i = 0; i < sel.options.length; i++) {
                    var o = sel.options[i];
                    if (norm(o.value) === dn || norm(o.textContent) === dn) { match = o; break; }
                  }
                  if (match) {
                    sel.value = match.value;
                    dispatchChange(sel);
                  } else {
                    sel.selectedIndex = -1;
                    if (def.valueAttr) card.setAttribute(def.valueAttr, '');
                    if (def.labelAttr) card.setAttribute(def.labelAttr, '');
                    clearProperty(def.prop);
                    dispatchChange(sel);
                    clearProperty(def.prop);
                  }
                }

                function applyFinish(card) {
                  var desired = getDesired(['hardware_finish', 'door_config_options.finish', 'finish']);
                  if (desired == null) return;
                  var dn = norm(desired);
                  var swatches = Array.prototype.slice.call(card.querySelectorAll('.door-suggested-hardware-swatch'));
                  var match = null;
                  swatches.forEach(function (sw) {
                    if (match) return;
                    var v = sw.getAttribute('data-finish-value') || '';
                    var l = sw.getAttribute('data-finish-label') || sw.getAttribute('title') || sw.getAttribute('aria-label') || '';
                    if (norm(v) === dn || norm(l) === dn) match = sw;
                  });
                  if (match) {
                    match.click();
                  } else {
                    swatches.forEach(function (sw) { sw.classList.remove('door-suggested-hardware-swatch--selected'); });
                    card.setAttribute('data-hw-finish-value', '');
                    card.setAttribute('data-hw-finish-label', '');
                    var fl = card.querySelector('[data-finish-label]');
                    if (fl) fl.textContent = '';
                    clearProperty('Finish');
                  }
                }

                function applyAll() {
                  var root = document.querySelector('[data-landing-hardware-config="1"]');
                  if (!root) return;
                  var card = root.querySelector('.door-suggested-hardware-card');
                  if (!card) return;
                  applyFinish(card);
                  SELECT_FIELDS.forEach(function (def) { applySelect(card, def); });
                }

                function boot() {
                  applyAll();
                  setTimeout(applyAll, 300);
                }

                if (document.readyState === 'complete') {
                  boot();
                } else {
                  window.addEventListener('load', boot);
                }
              })();
            </script>
