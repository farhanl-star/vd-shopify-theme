            assign mw_custom_length_opt = null
            assign mw_baluster_select_id = 'millwork-baluster-length-' | append: product.id
            assign mw_custom_length_select_id = 'millwork-custom-length-' | append: product.id
            assign mw_custom_thickness_select_id = 'millwork-custom-thickness-' | append: product.id
            assign show_millwork_baluster_length = false
            assign show_millwork_custom_length = false
            assign mw_labor_includes_length = false
            assign mw_baluster_option_count = 0
            assign mw_baluster_label = 'Baluster Length'
            assign mw_custom_length_label = 'Length'
          -%}
          {%- if _mw_door_opts != blank -%}
            {%- for opt in _mw_door_opts -%}
              {%- assign opt_key = opt.key | default: opt['key'] | downcase | strip | replace: '-', '_' | replace: ' ', '_' -%}
              {%- if opt_key == 'millwork_baluster_length' and mw_baluster_opt == null -%}
                {%- assign mw_baluster_opt = opt -%}
              {%- elsif opt_key == 'millwork_custom_length' and mw_custom_length_opt == null -%}
                {%- assign mw_custom_length_opt = opt -%}
              {%- elsif opt_key == 'labor_includes_length' -%}
                {%- assign mw_labor_includes_length = true -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if mw_custom_length_opt != blank -%}
            {%- assign mw_custom_length_label_field = mw_custom_length_opt.label | default: mw_custom_length_opt['label'] -%}
            {%- assign mw_custom_length_label = mw_custom_length_label_field | default: 'Length' -%}
            {%- assign show_millwork_custom_length = true -%}
          {%- endif -%}
          {%- if mw_baluster_opt != blank -%}
            {%- assign mw_baluster_label_field = mw_baluster_opt.label | default: mw_baluster_opt['label'] -%}
            {%- assign mw_baluster_label = mw_baluster_label_field | default: 'Baluster Length' -%}
            {%- assign mw_baluster_choice_refs = mw_baluster_opt.choices1.value | default: mw_baluster_opt.choices.value -%}
            {%- if mw_baluster_choice_refs != blank -%}
              {%- for c in mw_baluster_choice_refs -%}
                {%- assign c_value = c.value | default: c.value -%}
                {%- if c_value != blank -%}
                  {%- assign mw_baluster_option_count = mw_baluster_option_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
          {%- if mw_baluster_option_count > 0 -%}
            {%- assign show_millwork_baluster_length = true -%}
          {%- endif -%}

          {%- comment -%}
            Millwork Length — direct from product metafield custom.millwork_length_option only.
          {%- endcomment -%}
          {%- liquid
            assign _mw_length_catalog = shop.metaobjects.millwork_length.values | default: shop.metaobjects['millwork_length'].values
            assign _mw_ml_list = product.metafields.custom.millwork_length_option.value | default: product.metafields.custom.millwork_length_option
            assign mw_length_select_id = 'millwork-length-' | append: product.id
            assign show_millwork_length = false
            assign mw_length_option_count = 0
          -%}
          {%- if _mw_ml_list != blank -%}
            {%- for lo_ref in _mw_ml_list -%}
              {%- assign lo_mo = lo_ref | metaobject | default: lo_ref -%}
              {%- assign lo_hdl = lo_mo.system.handle | default: '' | strip -%}
              {%- assign mo_entry = nil -%}
              {%- if lo_hdl != blank -%}
                {%- assign mo_entry = shop.metaobjects.millwork_length[lo_hdl] | default: shop.metaobjects['millwork_length'][lo_hdl] -%}
              {%- endif -%}
              {%- if mo_entry == blank and lo_mo.system.id != blank and _mw_length_catalog != blank -%}
                {%- for cat_entry in _mw_length_catalog -%}
                  {%- if cat_entry.system.id == lo_mo.system.id -%}
                    {%- assign mo_entry = cat_entry -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if mo_entry == blank -%}
                {%- assign mo_entry = lo_mo -%}
              {%- endif -%}
              {%- if mo_entry != blank -%}
                {%- assign lo_key = mo_entry['key'].value | default: mo_entry.key.value | default: mo_entry['key'] | default: mo_entry.key | strip -%}
                {%- assign lo_val = mo_entry['value'].value | default: mo_entry.value.value | default: mo_entry['value'] | default: mo_entry.value | strip -%}
                {%- if lo_key == 'MetaobjectListDrop' -%}{%- assign lo_key = '' -%}{%- endif -%}
                {%- if lo_val == 'MetaobjectListDrop' -%}{%- assign lo_val = '' -%}{%- endif -%}
                {%- if lo_key != blank or lo_val != blank -%}
                  {%- assign mw_length_option_count = mw_length_option_count | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if mw_length_option_count > 0 -%}
            {%- assign show_millwork_length = true -%}
          {%- endif -%}

          <div class="millwork-accordion">
            <details class="m-collapsible">
              <summary class="m-collapsible--button millwork-select-summary">
                <div class="millwork-select-summary__left">
                  <div id="millwork-selected-preview" class="millwork-select-summary__thumb">
                    <img id="millwork-selected-image" src="" alt="">
                  </div>
                  <div>
                    <div class="millwork-select-summary__text">
                      <div class="millwork-select-summary__value" id="millwork-selected-label">Choose wood</div>
                      <strong id="landing-starting-price1"></strong>
                    </div>
                    {% comment %}
                      <div>
                        <strong id="landing-starting-price1">{{ product.price | money_without_trailing_zeros }}</strong>
                      </div>
                    {% endcomment %}
                  </div>
                  {% comment %}
                    <div class="millwork-select-summary__text">
                      <div class="millwork-select-summary__value" id="millwork-selected-label">Choose an option</div>
                    </div>
                  {% endcomment %}
                </div>
                <span class="millwork-select-summary__caret" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.5 7.5L10 12L14.5 7.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </summary>
              <div class="m-collapsible--content">
                <div class="m-collapsible--content__inner">
                  {% comment %}
                    <div id="millwork-selected-preview" style="display:flex;align-items:center;gap:12px;margin-bottom:12px;" >
                      <img id="millwork-selected-image" src="" alt="" >
                      <div>
                        <div class="millwork-select-summary__text">
                          <div class="millwork-select-summary__value" id="millwork-selected-label">Choose wood</div>
                        </div>
                      </div>
                    </div>
                  {% endcomment %}
                  <div class="millwork-options">
                    {%- assign category_csv = '' -%}
                    {%- for entry in shop.metaobjects.millwork_wood_catalog.values -%}
                      {%- assign cat = entry.category.value | default: '' | strip | downcase -%}
                      {%- if cat != blank -%}
                        {%- assign category_csv = category_csv | append: cat | append: '|' -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- assign categories = category_csv | split: '|' | uniq -%}

                    {%- for category in categories -%}
                      {%- assign category = category | strip | downcase -%}
                      {%- if category != blank -%}
                        <div class="millwork-options-group" data-category="{{ category | escape }}">
                          <div class="millwork-group-title">{{ category | capitalize }} Exposure</div>
                          {%- if category == 'any' -%}
                            <div class="millwork-group-desc">
                              Great for all locations, including direct exposure to rain, sun, snow, etc.
                            </div>
                          {%- elsif category == 'partial' -%}
                            <div class="millwork-group-desc">
                              Partially exposed to some elements, such as rain, sun, snow, etc.
                            </div>
                          {%- elsif category == 'protected' -%}
                            <div class="millwork-group-desc">
                              Best for protected locations with limited direct weather exposure.
                            </div>
                          {%- else -%}
                            <div class="millwork-group-desc">Choose from available wood species in this group.</div>
                          {%- endif -%}

                          {% for entry in shop.metaobjects.millwork_wood_catalog.values %}
                            {% assign entry_category = entry.category.value | default: '' | strip | downcase %}
                            {% if entry_category == category %}
                              <div
                                class="millwork-option-item"
                                data-value="{{ entry.display_name.value | escape }}"
                                data-species-key="{{ entry.species_key.value | escape }}"
                                data-tier-id="{{ entry.tier_id.value | escape }}"
                                data-image="{{ entry.image_url.value | escape }}"
                                role="button"
                                tabindex="0"
                              >
                                {% if entry.image_url.value != blank %}
                                  <img
                                    class="millwork-option-image"
                                    src="{{ entry.image_url.value | escape }}"
                                    alt="{{ entry.display_name.value | escape }}"
                                  >
                                {% endif %}
                                <span class="millwork-option-label">{{ entry.display_name.value }}</span>
                              </div>
                            {% endif %}
                          {% endfor %}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <input type="hidden" id="millwork-selected" value="">
                  <input type="hidden" id="millwork-selected-price" value="">
                  <input type="hidden" id="millwork-selected-unit-price" value="">
                  <input type="hidden" id="millwork-selected-addon-price" value="">
                </div>
              </div>
            </details>
          </div>

          {%- if show_millwork_custom_length -%}
            <div class="landing-product__hardware-config landing-product__millwork-extra-config" data-millwork-custom-length-config="1">
              <div class="millwork-custom-dimensions-row">
                <div class="door-suggested-hardware-card__hw-field door-suggested-hardware-card__millwork-custom-length">
                  <label
                    class="door-suggested-hardware-card__hw-label door-suggested-hardware-card__millwork-custom-length-label"
                    for="{{ mw_custom_length_select_id }}"
                    id="{{ mw_custom_length_select_id }}-label"
                  >
                    {{ mw_custom_length_label | escape }}
                  </label>
                  <select
                    id="{{ mw_custom_length_select_id }}"
                    class="door-input-select door-suggested-hardware-card__hw-select door-suggested-hardware-card__millwork-custom-length-select door-millwork-custom-length-select"
                    data-millwork-custom-length-select="1"
                    data-config-option-id="millwork_custom_length"
                    aria-labelledby="{{ mw_custom_length_select_id }}-label"
                  >
                    <option value="" selected disabled>Select</option>
                    {%- for i in (1..100) -%}
                      <option value="{{ i }}">{{ i }}</option>
                    {%- endfor -%}
                  </select>
                </div>
                <div class="door-suggested-hardware-card__hw-field door-suggested-hardware-card__millwork-custom-thickness">
                  <label
                    class="door-suggested-hardware-card__hw-label door-suggested-hardware-card__millwork-custom-thickness-label"
                    for="{{ mw_custom_thickness_select_id }}"
                    id="{{ mw_custom_thickness_select_id }}-label"
                  >
                    Thickness
                  </label>
                  <select
                    id="{{ mw_custom_thickness_select_id }}"
                    class="door-input-select door-suggested-hardware-card__hw-select door-suggested-hardware-card__millwork-custom-thickness-select door-millwork-custom-thickness-select"
                    data-millwork-custom-thickness-select="1"
                    aria-labelledby="{{ mw_custom_thickness_select_id }}-label"
                  >
                    <option value="" selected disabled>Select</option>
                    <option value="0">0</option>
                    <option value="0.0625">1/16</option>
                    <option value="0.125">1/8</option>
                    <option value="0.25">1/4</option>
                    <option value="0.5">1/2</option>
                    <option value="0.1875">3/16</option>
                    <option value="0.375">3/8</option>
                    <option value="0.75">3/4</option>
                    <option value="0.3125">5/16</option>
                    <option value="0.625">5/8</option>
                    <option value="0.4375">7/16</option>
                    <option value="0.875">7/8</option>
                    <option value="0.5625">9/16</option>
                    <option value="0.6875">11/16</option>
                    <option value="0.8125">13/16</option>
                    <option value="0.9375">15/16</option>
                  </select>
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if show_millwork_baluster_length -%}
            <div class="landing-product__hardware-config landing-product__millwork-extra-config" data-millwork-baluster-length-config="1">
              <div class="door-suggested-hardware-card__hw-field door-suggested-hardware-card__millwork-baluster-length">
                <label
                  class="door-suggested-hardware-card__hw-label door-suggested-hardware-card__millwork-baluster-length-label"
                  for="{{ mw_baluster_select_id }}"
                  id="{{ mw_baluster_select_id }}-label"
                >
                  {{ mw_baluster_label | escape }}
                </label>
                <select
                  id="{{ mw_baluster_select_id }}"
                  class="door-input-select door-suggested-hardware-card__hw-select door-suggested-hardware-card__millwork-baluster-length-select door-millwork-baluster-length-select"
                  data-millwork-baluster-length-select="1"
                  data-config-option-id="millwork_baluster_length"
                  aria-labelledby="{{ mw_baluster_select_id }}-label"
                >
                  <option value="" selected disabled>Select</option>
                  {%- for c in mw_baluster_choice_refs -%}
                    {%- assign c_value = c.value | default: c.value -%}
                    {%- if c_value != blank -%}
                      {%- assign c_label = c.label | default: c.label | default: c.title | default: c.title | default: c_value -%}
                      <option value="{{ c_value | escape }}">{{ c_label | escape }}</option>
                    {%- endif -%}
                  {%- endfor -%}
                </select>
              </div>
            </div>
          {%- endif -%}

          {%- if show_millwork_length -%}
            <div class="landing-product__hardware-config landing-product__millwork-extra-config" data-millwork-length-config="1">
              <div class="door-suggested-hardware-card__hw-field door-suggested-hardware-card__millwork-length">
                <label
                  class="door-suggested-hardware-card__hw-label door-suggested-hardware-card__millwork-length-label"
                  for="{{ mw_length_select_id }}"
                  id="{{ mw_length_select_id }}-label"
                >
                  Millwork Length
                </label>
                <select
                  id="{{ mw_length_select_id }}"
                  class="door-input-select door-suggested-hardware-card__hw-select door-suggested-hardware-card__millwork-length-select door-millwork-length-select"
                  data-millwork-length-select="1"
                  aria-labelledby="{{ mw_length_select_id }}-label"
                >
                  {%- if _mw_ml_list != blank -%}
                    {%- for lo_ref in _mw_ml_list -%}
                      {%- assign lo_mo = lo_ref | metaobject | default: lo_ref -%}
                      {%- assign lo_hdl = lo_mo.system.handle | default: '' | strip -%}
                      {%- assign mo_entry = nil -%}
                      {%- if lo_hdl != blank -%}
                        {%- assign mo_entry = shop.metaobjects.millwork_length[lo_hdl]
                          | default: shop.metaobjects['millwork_length'][lo_hdl]
                        -%}
                      {%- endif -%}
                      {%- if mo_entry == blank and lo_mo.system.id != blank and _mw_length_catalog != blank -%}
                        {%- for cat_entry in _mw_length_catalog -%}
                          {%- if cat_entry.system.id == lo_mo.system.id -%}
                            {%- assign mo_entry = cat_entry -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                      {%- if mo_entry == blank -%}
                        {%- assign mo_entry = lo_mo -%}
                      {%- endif -%}
                      {%- if mo_entry != blank -%}
                        {%- assign c_value = mo_entry['key'].value
                          | default: mo_entry.key.value
                          | default: mo_entry['key']
                          | default: mo_entry.key
                          | strip
                        -%}
                        {%- assign c_label = mo_entry['value'].value
                          | default: mo_entry.value.value
                          | default: mo_entry['value']
                          | default: mo_entry.value
                          | default: c_value
                          | strip
                        -%}
                        {%- if c_value == 'MetaobjectListDrop' -%}{%- assign c_value = '' -%}{%- endif -%}
                        {%- if c_label == 'MetaobjectListDrop' -%}{%- assign c_label = '' -%}{%- endif -%}
                        {%- if c_value != blank or c_label != blank -%}
                          {%- assign c_value = c_value | default: c_label -%}
                          {%- assign c_label = c_label | default: c_value -%}
                          <option value="{{ c_value | escape }}">{{ c_label | escape }}</option>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                </select>
              </div>
            </div>
          {%- endif -%}

          {%- if show_millwork_length or show_millwork_baluster_length or show_millwork_custom_length -%}
            <style>
              .landing-product__millwork-extra-config {
                margin-top: 24px;
                margin-bottom: 0;
              }
              .landing-product__millwork-extra-config .door-suggested-hardware-card__hw-field {
                display: flex;
                gap: 8px;
                margin-bottom: 32px;
                align-items: center;
                flex-wrap: wrap;
              }
              .millwork-custom-dimensions-row {
                display: flex;
                flex-direction: row;
                flex-wrap: wrap;
                align-items: center;
                gap: 16px 24px;
                width: 100%;
                margin-bottom: 32px;
              }
              .millwork-custom-dimensions-row .door-suggested-hardware-card__hw-field {
                display: flex;
                margin-bottom: 0;
                flex: 1 1 auto;
                align-items: center;
              }
              .landing-product__millwork-extra-config .door-suggested-hardware-card__hw-label {
                display: inline-block;
                font-size: 16px;
                font-weight: 600;
                line-height: 150%;
                width: 140px;
              }
              .landing-product__millwork-extra-config .door-suggested-hardware-card__hw-select {
                max-width: 220px;
                min-width: 220px;
                width: 100%;
              }
              .landing-product__millwork-extra-config select.door-suggested-hardware-card__hw-select.door-native-select--enhanced {
                display: none !important;
              }
              .landing-product__millwork-extra-config .door-div-select {
                position: relative;
                display: inline-block;
                width: 100%;
                min-width: 220px;
                max-width: 220px;
              }
              .landing-product__millwork-extra-config .door-div-select__btn {
                border: 1px solid var(--secondary400Color);
                padding: 8px 16px;
                border-radius: 8px;
                font-family: var(--font-stack-body);
                font-weight: 400;
                font-size: 16px;
                line-height: 150%;
                color: var(--sootBlackColor);
                width: 100%;
                background: var(--silkWhiteColor);
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 10px;
                cursor: pointer;
              }
              .landing-product__millwork-extra-config .door-div-select__btn span.door-div-select__label {
                white-space: nowrap;
                text-overflow: ellipsis;
                overflow: hidden;
              }
              .landing-product__millwork-extra-config .door-div-select--open .door-div-select__btn {
                border-radius: 8px 8px 0 0;
                border-bottom-color: transparent;
              }
              .landing-product__millwork-extra-config .door-div-select__list {
                display: none;
                position: absolute;
                left: 0;
                right: 0;
                top: calc(100% - 3px);
                z-index: 50;
                border: 1px solid var(--secondary400Color);
                border-radius: 0 0 8px 8px;
                background: var(--silkWhiteColor);
                border-top: 0;
                max-height: 260px;
                overflow: auto;
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
              }
              .landing-product__millwork-extra-config .door-div-select--open .door-div-select__list {
                display: block;
              }
              .landing-product__millwork-extra-config .door-div-select__item {
                padding: 8px 16px;
                font-size: 16px;
                line-height: 150%;
                width: 100%;
                text-align: left;
                border: 0;
                background: transparent;
                cursor: pointer;
                font-family: var(--font-stack-body);
              }
              .landing-product__millwork-extra-config .door-div-select__item:hover {
                background: var(--secondary100Color);
              }
              .landing-product__millwork-extra-config .door-div-select__item[aria-selected='true'] {
                background: var(--greysColor);
                color: var(--sootBlackColor);
              }
              @media (max-width: 576px) {
                .landing-product__millwork-extra-config .door-suggested-hardware-card__hw-label,
                .landing-product__millwork-extra-config .door-div-select {
                  width: 100%;
                  min-width: 100%;
                  max-width: 100%;
                }
              }
            </style>
            <script src="{{ 'door-conf2-update.js' | asset_url }}" defer></script>
            <script src="{{ 'landing-product-save.js' | asset_url }}" defer></script>
          {%- endif -%}

          {% if product.type == 'Millwork' %}
            <div class="landing-product__price mt-32">
              <div class="start_price">
                <strong id="landing-starting-price" class="p-xl fw-600 primaryFont">
                  {{- product.price | money_without_trailing_zeros -}}
                </strong>
                as configured
              </div>
              {% if product.selected_or_first_available_variant.sku != blank %}
                <div class="product-sku">
                  <strong>Model </strong>
                  <div class="model-no">
                    <span id="variant-sku">
                      {{ product.selected_or_first_available_variant.sku }}
                    </span>
                  </div>
                </div>
              {% endif %}
            </div>
            <form class="millwork-form door-hidden" method="post" action="/cart/add" aria-hidden="true" tabindex="-1">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <div class="qty-wrapper">
                <input type="number" name="quantity" min="1" value="1" inputmode="numeric" tabindex="-1">
              </div>
            </form>
            {% render 'landing-product-save' %}
          {% endif %}

        {% else %}
          {% if product.type != 'Hardware' %}
            <a
              href="{{ product.url | within: collection }}"
              class="button button--primary landing-product__cta common-btn"
            >
              Customize and Buy
            </a>
          {% endif %}
        {% endif %}

        {% if product.metafields.custom.subheading %}
          <p class="landing-product__subheading p-xl color-primarys">
            {{ product.metafields.custom.subheading }}
          </p>
        {% endif %}

        {% if product.type != 'Hardware' %}
          <div class="landing-product__description">
            <h6 class="description_heading">{{ product.metafields.custom.description_heading }}</h6>
            {{ product.description }}
          </div>
        {% endif %}
        {%- comment -%} Optional richtext block (theme editor) — appears before Key features {%- endcomment -%}
        {%- assign pre_key_features_blocks = section.blocks | where: 'type', 'key_features_pre_richtext' -%}
        {%- if pre_key_features_blocks != blank -%}
          {%- assign pre_key_features_block = pre_key_features_blocks.first -%}
          {%- if pre_key_features_block.settings.heading != blank or pre_key_features_block.settings.body != blank -%}
            <div class="landing-product__key-features-pre rte" {{ pre_key_features_block.shopify_attributes }}>
              {%- if pre_key_features_block.settings.heading != blank -%}
                <h6 class="landing-product__key-features-pre-heading">
                  {{ pre_key_features_block.settings.heading | escape }}
                </h6>
              {%- endif -%}
              {%- if pre_key_features_block.settings.body != blank -%}
                <div class="landing-product__key-features-pre-body">
                  {{ pre_key_features_block.settings.body }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- assign mf = product.metafields.custom.key_features_group -%}
        {%- assign group_value = mf.value | default: mf | append: '' | strip -%}
        {%- if group_value != blank -%}
          {% render 'key-features-accordion', blocks: section.blocks, group_value: group_value %}
        {%- endif -%}

        {%- comment -%}
          Door Setup accordion (no collection filter; shown when block is present)
        {%- endcomment -%}
        {%- if product != blank -%}
          {%- assign door_setup_blocks = section.blocks | where: 'type', 'door_setup' -%}
          {%- if door_setup_blocks != blank -%}
            {%- assign block = door_setup_blocks.first -%}
            <div class="kfa door-setup m-faqs-section__content" {{ block.shopify_attributes }}>
              <details
                class="m-collapsible door-setup-collapsible mb-0"
                {% if block.settings.open_by_default %}
                  open
                {% endif %}
              >
                <summary class="m-collapsible--button door-setup-collapsible--button">
                  <span>{{ block.settings.heading | default: 'Door Setup' | escape }}</span>
                  <span class="m-collapsible--icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <rect x="7" width="2" height="16" rx="1" fill="#00476C"></rect>
                      <rect x="16" y="7" width="2" height="16" rx="1" transform="rotate(90 16 7)" fill="#00476C" class="vertical"></rect>
                    </svg>
                  </span>
                </summary>
                <div class="m-collapsible--content door-setup-collapsible--content">
                  <div class="m-collapsible--content__inner rte">
                    {%- if block.settings.intro != blank -%}
                      <div class="door-setup__intro rte">
                        {{ block.settings.intro }}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.items != blank -%}
                      <div class="door-setup__links rte">
                        {{ block.settings.items }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </details>
            </div>
          {%- endif -%}
        {%- endif -%}

        {% for block in section.blocks %}
          {% case block.type %}
              {% comment %}
                {% when 'accordion' %}
                    {% render 'product-accordion', block: block %}
              {% endcomment %}
          {% endcase %}

          {% if block.type == 'feature_bar' %}
            {% render 'product-feature-bar', block: block %}
          {% endif %}
        {% endfor %}
        {%- if product.type == 'Hardware' or product.type == 'Millwork' -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
<style>
  .door-setup .m-collapsible .m-collapsible--content.door-setup-collapsible--content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Plus button
    document.querySelectorAll('.qty-btn.plus').forEach(function (button) {
      button.addEventListener('click', function () {
        let input = this.parentElement.querySelector('input[name="quantity"]');
        let currentVal = parseInt(input.value) || 1;

        input.value = currentVal + 1;

        // Trigger change event
        input.dispatchEvent(new Event('change'));
      });
    });

    // Minus button
    document.querySelectorAll('.qty-btn.minus').forEach(function (button) {
      button.addEventListener('click', function () {
        let input = this.parentElement.querySelector('input[name="quantity"]');
        let currentVal = parseInt(input.value) || 1;
        let min = parseInt(input.getAttribute('min')) || 1;

        if (currentVal > min) {
          input.value = currentVal - 1;

          // Trigger change event
          input.dispatchEvent(new Event('change'));
        }
      });
    });
  });
</script>
{% if product.type == 'Millwork' %}
  <script>
    (function () {
      function skuComparable(v) {
        return String(v == null ? '' : v).trim().toLowerCase();
      }
      function skuStrict(v) {
        return skuComparable(v).replace(/[^a-z0-9]/g, '');
      }

      function toMoney(v) {
        var n = parseFloat(v);
        if (isNaN(n)) n = 0;
        return '$' + n.toFixed(2);
      }

      function formatMillworkDisplayPrice(v) {
        var n = parseFloat(v);
        if (isNaN(n) || n <= 0) return '';
        return toMoney(n);
      }

      function parseJsonObjectLike(raw) {
        if (raw == null || raw === '') return null;
        if (typeof raw === 'boolean') return null;
        if (typeof raw === 'string') {
          var trimmed = raw.trim();
          if (!trimmed || trimmed === 'true' || trimmed === 'false') return null;
          try { raw = JSON.parse(trimmed); } catch (eJson) { return null; }
        }
        if (!raw || typeof raw !== 'object' || Array.isArray(raw)) return null;
        return raw;
      }

      function looksLikeSkuDetails(obj) {
        if (!obj || typeof obj !== 'object') return false;
        return obj.width != null
          || obj.length != null
          || obj.thickness != null
          || obj.label_factor != null
          || obj.labor_rate != null;
      }

      function parseSkuDetails(row) {
        var keys = ['calculate_by_formula', 'details', 'pricing_details', 'sku_details'];
        if (row) {
          for (var i = 0; i < keys.length; i++) {
            var candidate = parseJsonObjectLike(readFieldFromRow(row, [keys[i]]));
            if (looksLikeSkuDetails(candidate)) return candidate;
          }
        }
        return {};
      }

      function parseTierMap(row) {
        var map = row && row.wood_prices_by_tier ? row.wood_prices_by_tier : readFieldFromRow(row, ['wood_prices_by_tier']);
        if (typeof map === 'string') {
          try { map = JSON.parse(map); } catch (e1) { map = {}; }
        }
        if (map && map.wood_prices_by_tier) map = map.wood_prices_by_tier;
        if (typeof map === 'string') {
          try { map = JSON.parse(map); } catch (e2) { map = {}; }
        }
        return (map && typeof map === 'object') ? map : {};
      }

      function ceilingToIncrement(value, increment) {
        var n = parseFloat(value);
        var step = parseFloat(increment);
        if (isNaN(n)) return 0;
        if (isNaN(step) || step <= 0) step = 0.05;
        return Math.ceil(n / step) * step;
      }

      function computeMillworkFormulaParts(details, lengthOverride, footCost) {
        details = details || {};
        var width = parseFloat(details.width);
        var length = lengthOverride != null ? parseFloat(lengthOverride) : parseFloat(details.length);
        var thickness = parseFloat(details.thickness);
        var foot = parseFloat(footCost);
        var labelFactor = parseFloat(details.label_factor);
        var laborRate = parseFloat(details.labor_rate);
        var fixed1 = parseFloat(details.fixed_1);
        var fixed2 = parseFloat(details.fixed_2);
        if (isNaN(fixed1) || fixed1 <= 0) fixed1 = 12;
        if (isNaN(fixed2) || fixed2 <= 0) fixed2 = 0.05;
        if (isNaN(width) || isNaN(length) || isNaN(thickness) || isNaN(foot) || isNaN(labelFactor) || isNaN(laborRate)) {
          return null;
        }
        var areaFactor = (width * length) / 144;
        var materialRaw = areaFactor * thickness * foot;
        var materialPart = materialRaw / 0.18;
        var simpleLabor = usesSimpleLaborFormula();
        var laborPart = simpleLabor
          ? laborRate * labelFactor
          : laborRate * labelFactor * length / fixed1;
        var subtotal = materialPart + laborPart;
        var unitPrice = ceilingToIncrement(subtotal, fixed2);
        return {
          width: width,
          length: length,
          thickness: thickness,
          footCost: foot,
          labelFactor: labelFactor,
          laborRate: laborRate,
          fixed1: fixed1,
          fixed2: fixed2,
          simpleLabor: simpleLabor,
          areaFactor: areaFactor,
          materialRaw: materialRaw,
          materialPart: materialPart,
          laborPart: laborPart,
          subtotalBeforeCeiling: subtotal,
          ceilingIncrement: fixed2,
          unitPrice: unitPrice
        };
      }

      /**
       * labor_includes_length in door_config_options → T2*D*G/fixed_1
       * Otherwise custom/baluster length UI → T2*D; fixed-length products → T2*D*G/fixed_1
       */
      function calculateMillworkFormulaPrice(details, lengthOverride, footCost) {
        var parts = computeMillworkFormulaParts(details, lengthOverride, footCost);
        return parts ? parts.unitPrice : 0;
      }

      function isTruthyField(val) {
        if (val === true || val === 1) return true;
        var s = String(val == null ? '' : val).trim().toLowerCase();
        return s === 'true' || s === '1' || s === 'yes';
      }

      function isFalsyField(val) {
        if (val === false || val === 0) return true;
        var s = String(val == null ? '' : val).trim().toLowerCase();
        return s === 'false' || s === '0' || s === 'no';
      }

      function readCalculatePricingFlag(pricingRow) {
        var raw = readFieldFromRow(pricingRow, ['calculate', 'use_calculate', 'calculate_pricing']);
        if (isTruthyField(raw)) return true;
        if (isFalsyField(raw)) return false;
        return false;
      }

      function getTierDirectPrice(tierId) {
        var price = parseFloat(tierMap[tierId]);
        return isNaN(price) ? 0 : price;
      }

      function getTierFootCost(tierId) {
        return getTierDirectPrice(tierId);
      }

      function readFieldFromRow(row, keys) {
        if (!row) return null;
        for (var i = 0; i < keys.length; i++) {
          var k = keys[i];
          var direct = row[k];
          if (direct != null && String(direct).trim() !== '') return direct;
        }
        return null;
      }

      function findRowBySku(rows, sku) {
        var want = skuComparable(sku);
        var wantStrict = skuStrict(sku);
        for (var i = 0; i < rows.length; i++) {
          var row = rows[i] || {};
          var rowSku = skuComparable(readFieldFromRow(row, ['sku', 'product_key']));
          var rowHandle = skuComparable(readFieldFromRow(row, ['handle']));
          var rowDisplay = skuComparable(readFieldFromRow(row, ['display_name', 'title', 'name', 'product_key']));
          if (rowSku && rowSku === want) return row;
          if (rowHandle && rowHandle === want) return row;
          if (rowDisplay && rowDisplay === want) return row;
          if (rowSku && skuStrict(rowSku) === wantStrict) return row;
          if (rowHandle && skuStrict(rowHandle) === wantStrict) return row;
          if (rowDisplay && skuStrict(rowDisplay) === wantStrict) return row;
        }
        return null;
      }

      function resolveRuntimeSku() {
        var s = skuComparable(window.millwork_current_sku || '');
        if (s) return s;
        var fromLabel = skuComparable((document.getElementById('variant-sku') || {}).textContent || '');
        if (fromLabel) return fromLabel;
        var fromMetaKey = skuComparable({{ product.metafields.custom.pricing_record_key.value | json }});
        if (fromMetaKey) return fromMetaKey;
        return '';
      }

      var root = document.querySelector('.millwork-accordion');
      if (!root) return;

      var items = Array.from(root.querySelectorAll('.millwork-option-item'));
      var hiddenInput = root.querySelector('#millwork-selected');
      var hiddenPriceInput = root.querySelector('#millwork-selected-price');
      var hiddenUnitPriceInput = root.querySelector('#millwork-selected-unit-price');
      var hiddenAddonInput = root.querySelector('#millwork-selected-addon-price');
      var selectedLabel = document.getElementById('millwork-selected-label');
      var selectedImage = document.getElementById('millwork-selected-image');
      var priceEl = document.getElementById('landing-starting-price1');
      var configuredPriceEl = document.getElementById('landing-starting-price');
      var forms = Array.from(document.querySelectorAll('form.millwork-form'));
      var millworkDetails = root.querySelector('details.m-collapsible');
      var lengthSelect = document.querySelector('[data-millwork-length-select]');
      var customLengthSelect = document.querySelector('[data-millwork-custom-length-select]');
      var customThicknessSelect = document.querySelector('[data-millwork-custom-thickness-select]');
      var balusterSelect = document.querySelector('[data-millwork-baluster-length-select]');
      var balusterPropertyLabel = {{ mw_baluster_label | json }};
      var customLengthPropertyLabel = {{ mw_custom_length_label | json }};
      var laborIncludesLength = {{ mw_labor_includes_length | json }};

      function usesSimpleLaborFormula() {
        if (laborIncludesLength) return false;
        return !!(customLengthSelect || balusterSelect);
      }

      var sku = '';
      var row = null;
      var tierMap = {};
      var skuDetails = {};
      var useCalculatePricing = false;

      function refreshPricingContext() {
        sku = resolveRuntimeSku();
        var records = Array.isArray(window.millwork_pricing_records) ? window.millwork_pricing_records : [];
        row = findRowBySku(records, sku);
        tierMap = parseTierMap(row || {});
        skuDetails = parseSkuDetails(row);
        useCalculatePricing = readCalculatePricingFlag(row);
      }

      refreshPricingContext();

      function getSelectedCustomLengthOnly() {
        if (!customLengthSelect || customLengthSelect.selectedIndex < 0) return null;
        var customOpt = customLengthSelect.options[customLengthSelect.selectedIndex];
        if (!customOpt) return null;
        var customVal = String(customOpt.value || '').trim();
        if (!customVal) return null;
        var customNum = parseFloat(customVal);
        return isNaN(customNum) || customNum <= 0 ? null : customNum;
      }

      function getSelectedMetaobjectLengthInches() {
        if (!lengthSelect || lengthSelect.selectedIndex < 0) return null;
        var lengthOpt = lengthSelect.options[lengthSelect.selectedIndex];
        if (!lengthOpt) return null;
        var lengthVal = String(lengthOpt.value || '').trim();
        var lengthNum = parseFloat(lengthVal);
        if (!isNaN(lengthNum) && lengthNum > 0) return lengthNum;
        var lengthLabel = String(lengthOpt.textContent || '').trim();
        var match = lengthLabel.match(/(\d+(?:\.\d+)?)/);
        if (match) {
          lengthNum = parseFloat(match[1]);
          if (!isNaN(lengthNum) && lengthNum > 0) return lengthNum;
        }
        return null;
      }

      function roundLengthWithThicknessAddon(baseLength, thicknessAddon) {
        var base = parseFloat(baseLength);
        var addon = parseFloat(thicknessAddon);
        if (isNaN(base)) return 0;
        if (isNaN(addon)) addon = 0;
        var combined = base + addon;
        var whole = Math.floor(combined);
        var frac = combined - whole;
        if (frac > 0.5) return whole + 1;
        return whole;
      }

      function getSelectedBalusterLengthOnly() {
        if (!balusterSelect || balusterSelect.selectedIndex < 0) return null;
        var balusterOpt = balusterSelect.options[balusterSelect.selectedIndex];
        if (!balusterOpt) return null;
        var balusterVal = String(balusterOpt.value || '').trim();
        if (!balusterVal) return null;
        var balusterNum = parseFloat(balusterVal);
        if (!isNaN(balusterNum) && balusterNum > 0) return balusterNum;
        var balusterLabel = String(balusterOpt.textContent || '').trim();
        var balusterMatch = balusterLabel.match(/(\d+(?:\.\d+)?)/);
        if (balusterMatch) {
          balusterNum = parseFloat(balusterMatch[1]);
          if (!isNaN(balusterNum) && balusterNum > 0) return balusterNum;
        }
        return null;
      }

      function getBalusterLengthBaseForFormula() {
        var balusterBase = getSelectedBalusterLengthOnly();
        if (balusterBase != null) return balusterBase;
        var fallback = parseFloat(skuDetails.length);
        return isNaN(fallback) ? 12 : fallback;
      }

      function getCustomLengthBaseForFormula() {
        var customBase = getSelectedCustomLengthOnly();
        if (customBase != null) return customBase;
        var fallback = parseFloat(skuDetails.length);
        return isNaN(fallback) ? 12 : fallback;
      }

      function getResolvedLengthInches() {
        if (customLengthSelect) {
          var baseLength = getCustomLengthBaseForFormula();
          var thicknessAddon = getSelectedCustomThickness();
          if (thicknessAddon != null && !isNaN(thicknessAddon)) {
            return roundLengthWithThicknessAddon(baseLength, thicknessAddon);
          }
          return baseLength;
        }

        if (balusterSelect) {
          return getBalusterLengthBaseForFormula();
        }

        var metaLength = getSelectedMetaobjectLengthInches();
        if (metaLength != null && !isNaN(metaLength)) return metaLength;

        var fallback = parseFloat(skuDetails.length);
        return isNaN(fallback) ? 0 : fallback;
      }

      function getSelectedCustomThickness() {
        if (!customThicknessSelect || customThicknessSelect.selectedIndex < 0) return null;
        var thicknessOpt = customThicknessSelect.options[customThicknessSelect.selectedIndex];
        if (!thicknessOpt) return null;
        var thicknessVal = String(thicknessOpt.value || '').trim();
        if (thicknessVal === '') return null;
        var thicknessNum = parseFloat(thicknessVal);
        return isNaN(thicknessNum) ? null : thicknessNum;
      }

      function getPricingDetails() {
        return Object.assign({}, skuDetails);
      }

      function resolveDirectTierUnitPrice(tierId) {
        refreshPricingContext();
        return getTierDirectPrice(tierId);
      }

      function resolveFormulaUnitPrice(tierId) {
        refreshPricingContext();
        var length = getResolvedLengthInches();
        var footCost = getTierFootCost(tierId);
        return calculateMillworkFormulaPrice(getPricingDetails(), length, footCost);
      }

      function resolveConfiguredUnitPrice(tierId) {
        if (useCalculatePricing) {
          return resolveFormulaUnitPrice(tierId);
        }
        return resolveDirectTierUnitPrice(tierId);
      }

      function getQty() {
        if (!forms.length) return 1;
        var input = forms[0].querySelector('input[name="quantity"]');
        var q = parseInt(input && input.value, 10);
        return Number.isFinite(q) && q > 0 ? q : 1;
      }

      function ensurePropertyInput(form, key, value) {
        if (!form) return;
        var name = 'properties[' + key + ']';
        var el = form.querySelector('input[name="' + name + '"]');
        if (!el) {
          el = document.createElement('input');
          el.type = 'hidden';
          el.name = name;
          form.appendChild(el);
        }
        el.value = String(value == null ? '' : value);
      }

      function syncMillworkLengthProperty() {
        if (!lengthSelect || lengthSelect.selectedIndex < 0) return;
        var lengthOpt = lengthSelect.options[lengthSelect.selectedIndex];
        if (!lengthOpt) return;
        var lengthVal = String(lengthOpt.value || '');
        var lengthLbl = String(lengthOpt.textContent || '').trim();
        forms.forEach(function (form) {
          ensurePropertyInput(form, 'Millwork Length', lengthLbl || lengthVal);
        });
      }

      function syncMillworkBalusterLengthProperty() {
        if (!balusterSelect || balusterSelect.selectedIndex < 0) return;
        var balusterOpt = balusterSelect.options[balusterSelect.selectedIndex];
        if (!balusterOpt) return;
        var balusterVal = String(balusterOpt.value || '').trim();
        if (!balusterVal) return;
        var balusterLbl = String(balusterOpt.textContent || '').trim();
        var propertyKey = String(balusterPropertyLabel || 'Baluster Length');
        forms.forEach(function (form) {
          ensurePropertyInput(form, propertyKey, balusterLbl || balusterVal);
        });
      }

      function syncMillworkCustomLengthProperty() {
        if (!customLengthSelect) return;
        var propertyKey = String(customLengthPropertyLabel || 'Length');
        var customBase = getSelectedCustomLengthOnly();
        var thicknessAddon = getSelectedCustomThickness();

        if (customBase != null) {
          var valueToStore = customBase;
          if (thicknessAddon != null && !isNaN(thicknessAddon)) {
            valueToStore = getResolvedLengthInches();
          }
          forms.forEach(function (form) {
            ensurePropertyInput(form, propertyKey, String(valueToStore));
          });
          return;
        }

        if (thicknessAddon != null && !isNaN(thicknessAddon)) {
          forms.forEach(function (form) {
            ensurePropertyInput(form, propertyKey, String(getResolvedLengthInches()));
          });
        }
      }

      function syncMillworkCustomThicknessProperty() {
        if (!customThicknessSelect || customThicknessSelect.selectedIndex < 0) return;
        var thicknessOpt = customThicknessSelect.options[customThicknessSelect.selectedIndex];
        if (!thicknessOpt) return;
        var thicknessVal = String(thicknessOpt.value || '').trim();
        if (thicknessVal === '') return;
        var thicknessLbl = String(thicknessOpt.textContent || '').trim();
        forms.forEach(function (form) {
          ensurePropertyInput(form, 'Thickness', thicknessLbl || thicknessVal);
        });
      }

      function syncMillworkOptionProperties() {
        syncMillworkLengthProperty();
        syncMillworkCustomLengthProperty();
        syncMillworkCustomThicknessProperty();
        syncMillworkBalusterLengthProperty();
      }

      function syncForms(value, tierId, addon, unitTotal, lineTotal, qty) {
        forms.forEach(function (form) {
          ensurePropertyInput(form, 'Wood Species', value);
          ensurePropertyInput(form, 'Wood Tier', tierId);
          ensurePropertyInput(form, 'Quantity', qty);
          ensurePropertyInput(form, 'Wood Add-on', addon.toFixed(2));
          ensurePropertyInput(form, 'Configured Unit Price', unitTotal.toFixed(2));
          ensurePropertyInput(form, 'Configured Line Total', lineTotal.toFixed(2));
        });
        syncMillworkOptionProperties();
      }

      function setSelected(el, closePanel) {
        if (!el) return;

        items.forEach(function (i) { i.classList.remove('is-selected'); });
        el.classList.add('is-selected');

        var value = el.getAttribute('data-value') || '';
        var image = el.getAttribute('data-image') || '';
        var tierId = el.getAttribute('data-tier-id') || '';
        var unitTotal = resolveConfiguredUnitPrice(tierId);
        var addon = unitTotal;
        var qty = getQty();
        var total = unitTotal * qty;

        if (hiddenInput) hiddenInput.value = value;
        if (hiddenPriceInput) hiddenPriceInput.value = total.toFixed(2);
        if (hiddenUnitPriceInput) hiddenUnitPriceInput.value = unitTotal.toFixed(2);
        if (hiddenAddonInput) hiddenAddonInput.value = addon.toFixed(2);
        if (selectedLabel) selectedLabel.textContent = value || 'Choose an option';
        if (selectedImage) {
          if (image) {
            selectedImage.src = image;
            selectedImage.style.display = 'block';
          } else {
            selectedImage.style.display = 'none';
          }
        }

        if (priceEl) priceEl.textContent = formatMillworkDisplayPrice(unitTotal);
        if (configuredPriceEl) configuredPriceEl.textContent = formatMillworkDisplayPrice(total);
        var estimated = document.getElementById('door-estimated-price');
        if (estimated) estimated.textContent = formatMillworkDisplayPrice(total);
        syncForms(value, tierId, addon, unitTotal, total, qty);
        if (closePanel && millworkDetails) millworkDetails.removeAttribute('open');
      }

      items.forEach(function (el) {
        el.addEventListener('click', function () { setSelected(el, true); });
        el.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            setSelected(el, true);
          }
        });
      });

      forms.forEach(function (form) {
        var wrappers = Array.from(form.querySelectorAll('.qty-wrapper'));
        wrappers.forEach(function (wrapper) {
          var input = wrapper.querySelector('input[name="quantity"]');
          if (!input) return;

          function refreshPrice() {
            var active = root.querySelector('.millwork-option-item.is-selected') || items[0];
            if (active) setSelected(active, false);
          }
          input.addEventListener('change', refreshPrice);
          input.addEventListener('input', refreshPrice);
        });

        // Ensure latest qty/selection totals are persisted before cart submit.
        form.addEventListener('submit', function () {
          var active = root.querySelector('.millwork-option-item.is-selected') || items[0];
          if (active) setSelected(active, false);
          syncMillworkOptionProperties();
        });
      });

      function refreshSelectedMillworkPrice() {
        var active = root.querySelector('.millwork-option-item.is-selected') || items[0];
        if (active) setSelected(active, false);
      }

      if (lengthSelect) {
        lengthSelect.addEventListener('change', function () {
          syncMillworkLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        lengthSelect.addEventListener('input', function () {
          syncMillworkLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        function enhanceMillworkLengthSelect() {
          if (typeof window.__bootMillworkLengthConfig === 'function') {
            window.__bootMillworkLengthConfig();
          } else if (typeof window.__landingHardwareEnhanceSelect === 'function') {
            window.__landingHardwareEnhanceSelect(lengthSelect);
          } else {
            setTimeout(enhanceMillworkLengthSelect, 100);
          }
        }
        enhanceMillworkLengthSelect();
        syncMillworkLengthProperty();
      }

      if (balusterSelect) {
        balusterSelect.addEventListener('change', function () {
          syncMillworkBalusterLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        balusterSelect.addEventListener('input', function () {
          syncMillworkBalusterLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        function enhanceMillworkBalusterLengthSelect() {
          if (typeof window.__bootMillworkLengthConfig === 'function') {
            window.__bootMillworkLengthConfig();
          } else if (typeof window.__landingHardwareEnhanceSelect === 'function') {
            window.__landingHardwareEnhanceSelect(balusterSelect);
          } else {
            setTimeout(enhanceMillworkBalusterLengthSelect, 100);
          }
        }
        enhanceMillworkBalusterLengthSelect();
        syncMillworkBalusterLengthProperty();
      }

      if (customLengthSelect) {
        customLengthSelect.addEventListener('change', function () {
          syncMillworkCustomLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        customLengthSelect.addEventListener('input', function () {
          syncMillworkCustomLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        function enhanceMillworkCustomLengthSelect() {
          if (typeof window.__bootMillworkLengthConfig === 'function') {
            window.__bootMillworkLengthConfig();
          } else if (typeof window.__landingHardwareEnhanceSelect === 'function') {
            window.__landingHardwareEnhanceSelect(customLengthSelect);
          } else {
            setTimeout(enhanceMillworkCustomLengthSelect, 100);
          }
        }
        enhanceMillworkCustomLengthSelect();
        syncMillworkCustomLengthProperty();
      }

      if (customThicknessSelect) {
        customThicknessSelect.addEventListener('change', function () {
          syncMillworkCustomThicknessProperty();
          syncMillworkCustomLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        customThicknessSelect.addEventListener('input', function () {
          syncMillworkCustomThicknessProperty();
          syncMillworkCustomLengthProperty();
          refreshPricingContext();
          if (useCalculatePricing) refreshSelectedMillworkPrice();
        });
        function enhanceMillworkCustomThicknessSelect() {
          if (typeof window.__bootMillworkLengthConfig === 'function') {
            window.__bootMillworkLengthConfig();
          } else if (typeof window.__landingHardwareEnhanceSelect === 'function') {
            window.__landingHardwareEnhanceSelect(customThicknessSelect);
          } else {
            setTimeout(enhanceMillworkCustomThicknessSelect, 100);
          }
        }
        enhanceMillworkCustomThicknessSelect();
        syncMillworkCustomThicknessProperty();
      }

      function bootMillworkPricing(attempt) {
        attempt = attempt || 0;
        refreshPricingContext();
        var active = root.querySelector('.millwork-option-item.is-selected') || items[0];
        if (!active || !items.length) return;
        setSelected(active, false);
        var tierId = active.getAttribute('data-tier-id') || '';
        var unitTotal = resolveConfiguredUnitPrice(tierId);
        if (unitTotal <= 0 && attempt < 6 && useCalculatePricing) {
          setTimeout(function () { bootMillworkPricing(attempt + 1); }, attempt * 100);
        }
      }

      bootMillworkPricing(0);
    })();
  </script>
{% endif %}

