<section class="landing-product pt-24 pb-48">
  <div class="landing-product__inner page-width container">
    <div class="m:flex m:flex-wrap">
      <!-- LEFT: IMAGE -->
      <div class="landing-product__media m:column m:w-full lg:m:w-6/12">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.title | escape }}"
            loading="lazy"
          >
        {% endif %}
      </div>
      <div class="landing-product__content m:column m:w-full lg:m:w-6/12">
        {%- if product.type == 'Hardware' or product.type == 'Millwork' -%}
          {%- assign cp_zip = customer.default_address.zip | default: '' -%}
          <div
            id="landing-product-configurator"
            class="landing-product-configurator"
            data-api-base="https://vintage.espirevox.com"
            data-product-id="{{ product.id }}"
            data-product-name="{{ product.title | escape }}"
            data-product-handle="{{ product.handle }}"
            data-product-sku="{{ product.selected_or_first_available_variant.sku | escape }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            data-base-price="{{ product.price | divided_by: 100.0 }}"
            data-product-type="{{ product.type | escape }}"
            data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 600 }}{% endif %}"
            data-complete-profile-page-url="{{ pages['complete-profile'].url | default: '/pages/complete-profile' }}"
            {% if customer %}
            data-customer-email="{{ customer.email }}"
            data-customer-first-name="{{ customer.first_name | escape }}"
            data-customer-last-name="{{ customer.last_name | escape }}"
            data-customer-phone="{{ customer.phone | escape }}"
            data-customer-zip="{{ cp_zip | escape }}"
            data-profile-complete="{% if customer.first_name != blank and customer.phone != blank and cp_zip != blank %}1{% else %}0{% endif %}"
            {% endif %}
          >
        {%- endif -%}
        <div class="landing-product__header">
          <h5 class="landing-product__title">
            {{ product.title }}
          </h5>
        </div>
        {% if product.type == 'Millwork' %}
          <div class="landing-product__price" style="padding:0;border-bottom:0;"></div>
        {% endif %}

        {% if product.type != 'Millwork' %}
          <div class="landing-product__price">
            <div class="start_price">
              Starting at
              <strong id="landing-starting-price">{{ product.price | money_without_trailing_zeros }}</strong>
            </div>

            {% if product.selected_or_first_available_variant.sku != blank %}
              <div class="product-sku">
                <strong>Model </strong>
                <div class="model-no">
                  <span id="variant-sku">
                    {{ product.selected_or_first_available_variant.sku }}
                  </span>
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if product.type == 'Hardware' %}
          {%- liquid
            assign hw_finish_allow = product.metafields.custom.hardware_finish.value | default: product.metafields.custom.hardware_finish | default: ''
            assign hw_function_allow = product.metafields.custom.hardware_function.value | default: product.metafields.custom.hardware_function | default: ''
            assign hw_backset_val = product.metafields.custom.Door_Backset.value | default: product.metafields.custom.Door_Backset | default: product.metafields.custom.door_backset.value | default: product.metafields.custom.door_backset
            assign hw_backset_string = hw_backset_val | join: ','
            if hw_backset_string == blank
              assign hw_backset_string = hw_backset_val | default: ''
            endif
            assign hw_backset_items = hw_backset_string | split: ','

            assign hw_thickness_val = product.metafields.custom.hardware_thickness_option.value | default: product.metafields.custom.hardware_thickness_option
            assign hw_thickness_string = hw_thickness_val | join: ','
            if hw_thickness_string == blank
              assign hw_thickness_string = hw_thickness_val | default: ''
            endif
            assign hw_thickness_items = hw_thickness_string | split: ','

            assign hw_track_length_val = product.metafields.custom.door_hanger_tracker_length.value | default: product.metafields.custom.door_hanger_tracker_length | default: product.metafields.custom.track_length.value | default: product.metafields.custom.track_length
            assign hw_track_length_string = hw_track_length_val | join: ','
            if hw_track_length_string == blank
              assign hw_track_length_string = hw_track_length_val | default: ''
            endif
            assign hw_track_length_items = hw_track_length_string | split: ','
            assign hw_track_length_allow = hw_track_length_string

            assign hw_connected_doors_val = product.metafields.custom.number_of_connected_doors.value | default: product.metafields.custom.number_of_connected_doors | default: product.metafields.custom.connected_doors.value | default: product.metafields.custom.connected_doors
            assign hw_connected_doors_string = hw_connected_doors_val | join: ','
            if hw_connected_doors_string == blank
              assign hw_connected_doors_string = hw_connected_doors_val | default: ''
            endif
            assign hw_connected_doors_items = hw_connected_doors_string | split: ','
            assign hw_connected_doors_allow = hw_connected_doors_string

            assign hw_upper_track_length_val = product.metafields.custom.upper_track_length.value | default: product.metafields.custom.upper_track_length
            assign hw_upper_track_length_string = hw_upper_track_length_val | join: ','
            if hw_upper_track_length_string == blank
              assign hw_upper_track_length_string = hw_upper_track_length_val | default: ''
            endif
            assign hw_upper_track_length_items = hw_upper_track_length_string | split: ','
            assign hw_upper_track_length_allow = hw_upper_track_length_string

            assign hw_max_door_size_val = product.metafields.custom.max_door_size.value | default: product.metafields.custom.max_door_size
            assign hw_max_door_size_string = hw_max_door_size_val | join: ','
            if hw_max_door_size_string == blank
              assign hw_max_door_size_string = hw_max_door_size_val | default: ''
            endif
            assign hw_max_door_size_items = hw_max_door_size_string | split: ','
            assign hw_max_door_size_allow = hw_max_door_size_string

            assign hw_carriage_pack_type_val = product.metafields.custom.carriage_pack_type.value | default: product.metafields.custom.carriage_pack_type
            assign hw_carriage_pack_type_string = hw_carriage_pack_type_val | join: ','
            if hw_carriage_pack_type_string == blank
              assign hw_carriage_pack_type_string = hw_carriage_pack_type_val | default: ''
            endif
            assign hw_carriage_pack_type_items = hw_carriage_pack_type_string | split: ','
            assign hw_carriage_pack_type_allow = hw_carriage_pack_type_string

            assign hw_strap_hinge_length_val = product.metafields.custom.strap_hinge_length.value | default: product.metafields.custom.strap_hinge_length
            assign hw_strap_hinge_length_string = hw_strap_hinge_length_val | join: ','
            if hw_strap_hinge_length_string == blank
              assign hw_strap_hinge_length_string = hw_strap_hinge_length_val | default: ''
            endif
            assign hw_strap_hinge_length_items = hw_strap_hinge_length_string | split: ','
            assign hw_strap_hinge_length_allow = hw_strap_hinge_length_string

            assign hw_closer_color_val = product.metafields.custom.closer_color.value | default: product.metafields.custom.closer_color
            assign hw_closer_color_string = hw_closer_color_val | join: ','
            if hw_closer_color_string == blank
              assign hw_closer_color_string = hw_closer_color_val | default: ''
            endif
            assign hw_closer_color_items = hw_closer_color_string | split: ','
            assign hw_closer_color_allow = hw_closer_color_string

            assign hw_swing_direction_val = product.metafields.custom.swing_direction.value | default: product.metafields.custom.swing_direction
            assign hw_swing_direction_string = hw_swing_direction_val | join: ','
            if hw_swing_direction_string == blank
              assign hw_swing_direction_string = hw_swing_direction_val | default: ''
            endif
            assign hw_swing_direction_items = hw_swing_direction_string | split: ','
            assign hw_swing_direction_allow = hw_swing_direction_string

            assign hw_opts = product.metafields.custom.door_config_options.value
            assign hw_finish_opt = null
            assign hw_function_opt = null
            assign hw_closer_color_opt = null
            assign hw_swing_direction_opt = null
            assign hw_backset_opt = null
            assign hw_track_length_opt = null
            assign hw_connected_doors_opt = null
            assign hw_upper_track_length_opt = null
            assign hw_max_door_size_opt = null
            assign hw_carriage_pack_type_opt = null
            assign hw_strap_hinge_length_opt = null
          -%}
          {%- if hw_opts != blank -%}
            {%- for opt in hw_opts -%}
              {%- assign opt_key = opt.key | default: opt.key | downcase | strip -%}
              {%- if opt_key == 'finish' and hw_finish_opt == null -%}
                {%- assign hw_finish_opt = opt -%}
              {%- elsif opt_key == 'function' and hw_function_opt == null -%}
                {%- assign hw_function_opt = opt -%}
              {%- elsif opt_key == 'closer_color' or opt_key == 'closer-color' or opt_key == 'closer color' -%}
                {%- if hw_closer_color_opt == null -%}
                  {%- assign hw_closer_color_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'swing_direction' or opt_key == 'swing-direction' or opt_key == 'swing direction' -%}
                {%- if hw_swing_direction_opt == null -%}
                  {%- assign hw_swing_direction_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'door_backset' or opt_key == 'door-backset' or opt_key == 'door backset' or opt_key == 'backset' -%}
                {%- if hw_backset_opt == null -%}
                  {%- assign hw_backset_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'door_hanger_tracker_length'
                or opt_key == 'door-hanger-tracker-length'
                or opt_key == 'door hanger tracker length'
                or opt_key == 'track_length'
                or opt_key == 'track-length'
                or opt_key == 'track length'
              -%}
                {%- if hw_track_length_opt == null -%}
                  {%- assign hw_track_length_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'number_of_connected_doors'
                or opt_key == 'number-of-connected-doors'
                or opt_key == 'number of connected doors'
                or opt_key == 'connected_doors'
                or opt_key == 'connected doors'
              -%}
                {%- if hw_connected_doors_opt == null -%}
                  {%- assign hw_connected_doors_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'upper_track_length'
                or opt_key == 'upper-track-length'
                or opt_key == 'upper track length'
              -%}
                {%- if hw_upper_track_length_opt == null -%}
                  {%- assign hw_upper_track_length_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'max_door_size'
                or opt_key == 'max-door-size'
                or opt_key == 'max door size'
              -%}
                {%- if hw_max_door_size_opt == null -%}
                  {%- assign hw_max_door_size_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'carriage_pack_type'
                or opt_key == 'carriage-pack-type'
                or opt_key == 'carriage pack type'
              -%}
                {%- if hw_carriage_pack_type_opt == null -%}
                  {%- assign hw_carriage_pack_type_opt = opt -%}
                {%- endif -%}
              {%- elsif opt_key == 'strap_hinge_length'
                or opt_key == 'strap-hinge-length'
                or opt_key == 'strap hinge length'
              -%}
                {%- if hw_strap_hinge_length_opt == null -%}
                  {%- assign hw_strap_hinge_length_opt = opt -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          {%- assign show_hw_finish = false -%}
          {%- if hw_finish_allow != blank and hw_finish_opt != blank -%}
            {%- assign show_hw_finish = true -%}
          {%- endif -%}
          {%- assign show_hw_function = false -%}
          {%- if hw_function_allow != blank and hw_function_opt != blank -%}
            {%- assign show_hw_function = true -%}
          {%- endif -%}
          {%- assign show_hw_closer_color = false -%}
          {%- if hw_closer_color_opt != blank or hw_closer_color_string != blank -%}
            {%- assign show_hw_closer_color = true -%}
          {%- endif -%}
          {%- assign show_hw_thickness = false -%}
          {%- if hw_thickness_string != blank -%}
            {%- assign show_hw_thickness = true -%}
          {%- endif -%}
          {%- assign show_hw_swing_direction = false -%}
          {%- if hw_swing_direction_opt != blank or hw_swing_direction_string != blank -%}
            {%- assign show_hw_swing_direction = true -%}
          {%- endif -%}
          {%- assign show_hw_backset = false -%}
          {%- if hw_backset_opt != blank or hw_backset_string != blank -%}
            {%- assign show_hw_backset = true -%}
          {%- endif -%}
          {%- assign show_hw_track_length = false -%}
          {%- if hw_track_length_opt != blank or hw_track_length_string != blank -%}
            {%- assign show_hw_track_length = true -%}
          {%- endif -%}
          {%- assign show_hw_connected_doors = false -%}
          {%- if hw_connected_doors_opt != blank or hw_connected_doors_string != blank -%}
            {%- assign show_hw_connected_doors = true -%}
          {%- endif -%}
          {%- assign show_hw_upper_track_length = false -%}
          {%- if hw_upper_track_length_opt != blank or hw_upper_track_length_string != blank -%}
            {%- assign show_hw_upper_track_length = true -%}
          {%- endif -%}
          {%- assign show_hw_max_door_size = false -%}
          {%- if hw_max_door_size_opt != blank or hw_max_door_size_string != blank -%}
            {%- assign show_hw_max_door_size = true -%}
          {%- endif -%}
          {%- assign show_hw_carriage_pack_type = false -%}
          {%- if hw_carriage_pack_type_opt != blank or hw_carriage_pack_type_string != blank -%}
            {%- assign show_hw_carriage_pack_type = true -%}
          {%- endif -%}
          {%- assign show_hw_strap_hinge_length = false -%}
          {%- if hw_strap_hinge_length_opt != blank or hw_strap_hinge_length_string != blank -%}
            {%- assign show_hw_strap_hinge_length = true -%}
          {%- endif -%}

          {%- if show_hw_finish
            or show_hw_function
            or show_hw_closer_color
            or show_hw_thickness
            or show_hw_swing_direction
            or show_hw_backset
            or show_hw_track_length
            or show_hw_connected_doors
            or show_hw_upper_track_length
            or show_hw_max_door_size
            or show_hw_carriage_pack_type
            or show_hw_strap_hinge_length
          -%}
            {%- capture hw_finish_allow_pipe -%}
               {%- assign hw_finish_allow_items = hw_finish_allow | split: ',' -%}
               {%- for allow_item in hw_finish_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_function_allow_pipe -%}
               {%- assign hw_function_allow_items = hw_function_allow | split: ',' -%}
               {%- for allow_item in hw_function_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_closer_color_allow_pipe -%}
               {%- assign hw_closer_color_allow_items = hw_closer_color_allow | split: ',' -%}
               {%- for allow_item in hw_closer_color_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_swing_direction_allow_pipe -%}
               {%- assign hw_swing_direction_allow_items = hw_swing_direction_allow | split: ',' -%}
               {%- for allow_item in hw_swing_direction_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_track_length_allow_pipe -%}
               {%- assign hw_track_length_allow_items = hw_track_length_allow | split: ',' -%}
               {%- for allow_item in hw_track_length_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_connected_doors_allow_pipe -%}
               {%- assign hw_connected_doors_allow_items = hw_connected_doors_allow | split: ',' -%}
               {%- for allow_item in hw_connected_doors_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_upper_track_length_allow_pipe -%}
               {%- assign hw_upper_track_length_allow_items = hw_upper_track_length_allow | split: ',' -%}
               {%- for allow_item in hw_upper_track_length_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_max_door_size_allow_pipe -%}
               {%- assign hw_max_door_size_allow_items = hw_max_door_size_allow | split: ',' -%}
               {%- for allow_item in hw_max_door_size_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_carriage_pack_type_allow_pipe -%}
               {%- assign hw_carriage_pack_type_allow_items = hw_carriage_pack_type_allow | split: ',' -%}
               {%- for allow_item in hw_carriage_pack_type_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}
            {%- capture hw_strap_hinge_length_allow_pipe -%}
               {%- assign hw_strap_hinge_length_allow_items = hw_strap_hinge_length_allow | split: ',' -%}
               {%- for allow_item in hw_strap_hinge_length_allow_items -%}
                 |{{ allow_item | downcase | replace: '-', '_' | replace: ' ', '_' | strip }}|
               {%- endfor -%}
             {%- endcapture -%}

            {%- assign hw_product_id = product.id -%}
            {%- assign hw_fn_select_id = 'door-hw-fn-' | append: hw_product_id -%}
            {%- assign hw_cc_select_id = 'door-hw-cc-' | append: hw_product_id -%}
            {%- assign hw_thick_select_id = 'door-hw-thick-' | append: hw_product_id -%}
            {%- assign hw_sd_select_id = 'door-hw-sd-' | append: hw_product_id -%}
            {%- assign hw_bs_select_id = 'door-hw-bs-' | append: hw_product_id -%}
            {%- assign hw_tl_select_id = 'door-hw-tl-' | append: hw_product_id -%}
            {%- assign hw_cd_select_id = 'door-hw-cd-' | append: hw_product_id -%}
            {%- assign hw_utl_select_id = 'door-hw-utl-' | append: hw_product_id -%}
            {%- assign hw_mds_select_id = 'door-hw-mds-' | append: hw_product_id -%}
            {%- assign hw_cpt_select_id = 'door-hw-cpt-' | append: hw_product_id -%}
            {%- assign hw_shl_select_id = 'door-hw-shl-' | append: hw_product_id -%}
            {%- assign hw_first_finish_value = '' -%}
            {%- assign hw_first_finish_display = '' -%}
            {%- assign hw_first_function_value = '' -%}
            {%- assign hw_first_function_label = '' -%}
            {%- assign hw_first_closer_color_value = '' -%}
            {%- assign hw_first_closer_color_label = '' -%}
            {%- assign hw_first_thickness_value = '' -%}
            {%- assign hw_first_thickness_label = '' -%}
            {%- assign hw_first_swing_direction_value = '' -%}
            {%- assign hw_first_swing_direction_label = '' -%}
            {%- assign hw_first_backset_value = '' -%}
            {%- assign hw_first_backset_label = '' -%}
            {%- assign hw_first_track_length_value = '' -%}
            {%- assign hw_first_track_length_label = '' -%}
            {%- assign hw_first_connected_doors_value = '' -%}
            {%- assign hw_first_connected_doors_label = '' -%}
            {%- assign hw_first_upper_track_length_value = '' -%}
            {%- assign hw_first_upper_track_length_label = '' -%}
            {%- assign hw_first_max_door_size_value = '' -%}
            {%- assign hw_first_max_door_size_label = '' -%}
            {%- assign hw_first_carriage_pack_type_value = '' -%}
            {%- assign hw_first_carriage_pack_type_label = '' -%}
            {%- assign hw_first_strap_hinge_length_value = '' -%}
            {%- assign hw_first_strap_hinge_length_label = '' -%}

            {%- if show_hw_finish -%}
              {%- assign hw_finish_choice_refs = hw_finish_opt.choices1.value | default: hw_finish_opt.choices.value -%}
              {%- if hw_finish_choice_refs != blank -%}
                {%- for c in hw_finish_choice_refs -%}
                  {%- assign c_value = c.value | default: c.value -%}
                  {%- if c_value != blank -%}
                    {%- assign c_value_norm = c_value | downcase | replace: '-', '_' | replace: ' ', '_' | strip -%}
                    {%- assign c_value_check = '|' | append: c_value_norm | append: '|' -%}
                    {%- if hw_finish_allow_pipe contains c_value_check and hw_first_finish_value == blank -%}
                      {%- assign hw_first_finish_value = c_value -%}
                      {%- assign hw_first_finish_display = c.label
                        | default: c.label
                        | default: c.title
                        | default: c.title
                        | default: c_value
                      -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endif -%}

            {%- if show_hw_function -%}
              {%- assign hw_function_choice_refs = hw_function_opt.choices1.value
                | default: hw_function_opt.choices.value
              -%}
              {%- if hw_function_choice_refs != blank -%}
                {%- for c in hw_function_choice_refs -%}
                  {%- assign c_value = c.value | default: c.value -%}
                  {%- if c_value != blank -%}
                    {%- assign c_value_norm = c_value | downcase | replace: '-', '_' | replace: ' ', '_' | strip -%}
                    {%- assign c_value_check = '|' | append: c_value_norm | append: '|' -%}
                    {%- if hw_function_allow_pipe contains c_value_check and hw_first_function_value == blank -%}
                      {%- assign hw_first_function_value = c_value -%}
                      {%- assign hw_first_function_label = c.label
                        | default: c.label
                        | default: c.title
                        | default: c.title
                        | default: c_value
                      -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endif -%}

            {%- if show_hw_closer_color -%}
              {%- assign hw_closer_color_choice_refs = hw_closer_color_opt.choices1.value
                | default: hw_closer_color_opt.choices.value
              -%}
              {%- if hw_closer_color_choice_refs != blank -%}
                {%- for c in hw_closer_color_choice_refs -%}
                  {%- assign c_value = c.value | default: c.value -%}
                  {%- if c_value != blank -%}
                    {%- assign c_value_norm = c_value | downcase | replace: '-', '_' | replace: ' ', '_' | strip -%}
                    {%- assign c_value_check = '|' | append: c_value_norm | append: '|' -%}
                    {%- if hw_closer_color_allow == blank or hw_closer_color_allow_pipe contains c_value_check -%}
                      {%- if hw_first_closer_color_value == blank -%}
                        {%- assign hw_first_closer_color_value = c_value -%}
                        {%- assign hw_first_closer_color_label = c.label
                          | default: c.label
                          | default: c.title
                          | default: c.title
                          | default: c_value
