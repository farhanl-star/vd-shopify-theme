{% comment %}
  Recommended Products section – per-product recommendations.
  Supports: metafield (custom.recommended_products) or Shopify Recommendations API.
  Shows carousel/slider when more than 3 products.
  Add this section to your product template (e.g. product.json).
{% endcomment %}

{%- liquid
  assign source = section.settings.recommendations_source
  assign heading = section.settings.heading | default: 'Hardware That Belongs'
  assign subheading = section.settings.subheading
  assign body = section.settings.body
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign max_products = section.settings.max_products | default: 10
  assign rec_products = null

  if product and source == 'metafield' and product.metafields.custom.recommended_products != blank
    assign rec_products = product.metafields.custom.recommended_products.value
  endif
-%}

{%- if product -%}
<section
  class="recommended-products recommended-products--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-source="{{ source }}"
  data-max-products="{{ max_products }}"
  data-use-slider="{{ section.settings.use_slider_when_over_3 }}"
>
  <div class="recommended-products__inner page-width container">
    <div class="recommended-products__header common-center-div mb-40">
      {%- if heading != blank -%}
        <h5 class="recommended-products__title">{{ heading }}</h5>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="recommended-products__subheading common-header-desc mb-24">{{ subheading }}</p>
      {%- endif -%}
      {%- if body != blank -%}
        <div class="recommended-products__body common-left-div">{{ body }}</div>
      {%- endif -%}
    </div>

    <div class="recommended-products__products-wrapper" data-products-container>
      {%- if rec_products != null and rec_products.size > 0 -%}
        {%- assign product_count = rec_products.size -%}
        <div
          class="recommended-products__grid{% if product_count > 3 and section.settings.use_slider_when_over_3 %} recommended-products__grid--slider swiper{% endif %}"
          data-product-count="{{ product_count }}"
        >
          {%- if product_count > 3 and section.settings.use_slider_when_over_3 -%}
            <div class="swiper-wrapper">
              {%- for rec_product in rec_products -%}
                <div class="swiper-slide">
                  {%- render 'recommended-product-card', product: rec_product -%}
                </div>
              {%- endfor -%}
            </div>
            <div class="swiper-pagination recommended-products__pagination"></div>
            <button type="button" class="swiper-button-prev recommended-products__nav recommended-products__nav--prev" aria-label="Previous"></button>
            <button type="button" class="swiper-button-next recommended-products__nav recommended-products__nav--next" aria-label="Next"></button>
          {%- else -%}
            {%- for rec_product in rec_products -%}
              <div class="recommended-products__card-wrap">
                {%- render 'recommended-product-card', product: rec_product -%}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- elsif source == 'shopify_api' -%}
        <div class="recommended-products__grid recommended-products__grid--placeholder" data-recommendations-placeholder>
          <span class="recommended-products__loading" aria-hidden="true">Loading recommendations…</span>
        </div>
      {%- endif -%}
    </div>

    {%- if cta_text != blank -%}
      <div class="recommended-products__cta common-btn-div">
        <a href="{{ cta_url | default: routes.all_products_collection_url }}" class="recommended-products__button button button--ghost common-btn btn-bordered mx-auto ">
          {{ cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .recommended-products--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
</style>
<style>
  {% comment %} .recommended-products__inner { max-width: 1200px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .recommended-products__header { margin-bottom: 2rem; max-width: 640px; margin-left: auto; margin-right: auto; }
  .recommended-products__title { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 600; color: #1a1a1a; margin: 0 0 0.75rem; font-family: Georgia, 'Times New Roman', serif; }
  .recommended-products__subheading { font-size: 1.125rem; color: #4a4a4a; margin: 0 0 0.5rem; font-style: italic; }
  .recommended-products__body { font-size: 0.9375rem; line-height: 1.6; color: #555; margin: 0; }
  .recommended-products__products-wrapper { margin-bottom: 2rem; }
  .recommended-products__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; align-items: start; }
  @media (max-width: 768px) { .recommended-products__grid:not(.recommended-products__grid--slider) { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .recommended-products__grid:not(.recommended-products__grid--slider) { grid-template-columns: 1fr; } }
  .recommended-products__grid--slider { display: block; overflow: hidden; }
  .recommended-products__grid--slider .swiper-wrapper { display: flex; align-items: stretch; }
  .recommended-products__grid--slider .swiper-slide { height: auto; }
  .recommended-products__card-wrap { min-width: 0; }
  .recommended-products__card { display: block; text-decoration: none; color: inherit; }
  {% endcomment %}
  .recommended-products__card-image { width:100%;height:200px;margin-bottom:24px;}
  .recommended-products__card-image img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .recommended-products__card-title {font-size: 20px;line-height: 150%;letter-spacing: 0;text-align: center;color:var(--sootBlackColor);display:block;}
  .recommended-products__cta { margin-top: 40px;}
  .recommended-products__button { display: inline-block; padding: 0.75rem 1.5rem; border: 1px solid #1a1a1a; color: #1a1a1a; background: transparent; border-radius: 6px; text-decoration: none; font-size: 0.9375rem; transition: background 0.2s, color 0.2s; }
  .recommended-products__button:hover { background: #1a1a1a; color: #fff; }
  .recommended-products__loading { color: #888; font-size: 0.9375rem; }
  {% comment %} .recommended-products__nav { position: absolute; top: 50%; transform: translateY(-50%); z-index: 2; width: 44px; height: 44px; border: 1px solid #ccc; background: #fff; border-radius: 50%; cursor: pointer; }
  .recommended-products__nav--prev { left: -12px; }
  .recommended-products__nav--next { right: -12px; } {% endcomment %}
  @media screen and (max-width: 768px) {
    .recommended-products__card-image {width: 100%;height: 160px;}
    .recommended-products__card-title{font-size: 14px;line-height: 150%;letter-spacing: 0;text-align: center;}
  }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  (function() {
    const section = document.querySelector('.recommended-products--{{ section.id }}');
    if (!section) return;

    const source = section.dataset.source;
    const productId = section.dataset.productId;
    const maxProducts = parseInt(section.dataset.maxProducts, 10) || 10;
    const useSlider = section.dataset.useSlider === 'true';
    const container = section.querySelector('[data-products-container]');
    const placeholder = section.querySelector('[data-recommendations-placeholder]');

    function initSlider(wrap) {
      if (!useSlider || !wrap) return;
      const count = parseInt(wrap.dataset.productCount, 10);
      if (count <= 3) return;
      if (typeof Swiper === 'undefined') {
        setTimeout(function() { initSlider(wrap); }, 100);
        return;
      }
      new Swiper(wrap, {
        slidesPerView: 2,
        spaceBetween: 24,
        centeredSlides:true,
        loop:true,
        pagination: { el: wrap.querySelector('.swiper-pagination'), clickable: true },
        navigation: {
          nextEl: wrap.querySelector('.swiper-button-next'),
          prevEl: wrap.querySelector('.swiper-button-prev')
        },
        breakpoints: {
          480: { slidesPerView: 2 },
          768: { slidesPerView: 3 },
          1024: { slidesPerView: 3 }
        }
      });
    }

    if (source === 'shopify_api' && placeholder && productId) {
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=' + maxProducts)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          const products = data.products || [];
          if (products.length === 0) {
            placeholder.innerHTML = '';
            return;
          }
          const grid = document.createElement('div');
          grid.className = 'recommended-products__grid' + (products.length > 3 && useSlider ? ' recommended-products__grid--slider swiper' : '');
          grid.dataset.productCount = products.length;

          if (products.length > 3 && useSlider) {
            grid.innerHTML = '<div class="swiper-wrapper"></div><div class="swiper-pagination recommended-products__pagination"></div><button type="button" class="swiper-button-prev recommended-products__nav recommended-products__nav--prev" aria-label="Previous"></button><button type="button" class="swiper-button-next recommended-products__nav recommended-products__nav--next" aria-label="Next"></button>';
            const wrapper = grid.querySelector('.swiper-wrapper');
            products.forEach(function(p) {
              const slide = document.createElement('div');
              slide.className = 'swiper-slide';
              slide.innerHTML = renderProductCard(p);
              wrapper.appendChild(slide);
            });
          } else {
            products.forEach(function(p) {
              const wrap = document.createElement('div');
              wrap.className = 'recommended-products__card-wrap';
              wrap.innerHTML = renderProductCard(p);
              grid.appendChild(wrap);
            });
          }

          placeholder.replaceWith(grid);
          initSlider(grid);
        })
        .catch(function() { placeholder.innerHTML = ''; });
    } else {
      const grid = section.querySelector('.recommended-products__grid.recommended-products__grid--slider');
      initSlider(grid);
    }

    function renderProductCard(p) {
      const url = p.url || '#';
      const title = p.title || '';
      const img = p.featured_image && p.featured_image.src ? p.featured_image.src : (p.images && p.images[0] ? p.images[0].src : '');
      const alt = p.featured_image && p.featured_image.alt ? p.featured_image.alt : title;
      return '<a href="' + url + '" class="recommended-products__card">' +
        '<div class="recommended-products__card-image">' +
        (img ? '<img src="' + img + '" alt="' + alt.replace(/"/g, '&quot;') + '" loading="lazy" width="400" height="400">' : '') +
        '</div>' +
        '<span class="recommended-products__card-title">' + title + '</span>' +
        '</a>';
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Recommended products",
  "tag": "section",
  "class": "section-recommended-products",
  "settings": [
    {
      "type": "header",
      "content": "Recommendations source"
    },
    {
      "type": "select",
      "id": "recommendations_source",
      "label": "Source",
      "options": [
        { "value": "metafield", "label": "Product metafield (custom.recommended_products)" },
        { "value": "shopify_api", "label": "Shopify automatic recommendations" }
      ],
      "default": "shopify_api",
      "info": "Metafield: use a list of product references on each product. API: uses Shopify's recommendations engine."
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "use_slider_when_over_3",
      "label": "Use carousel when more than 3 products",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hardware That Belongs"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated for your project"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button label",
      "default": "Shop all hardware"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Recommended products",
      "settings": {}
    }
  ]
}
{% endschema %}
