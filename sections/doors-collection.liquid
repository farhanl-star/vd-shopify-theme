<section class="doors-section fade-section section-padding py-80">
  <div class="container">
    {% if section.settings.heading or section.settings.subheading %}
      <div class="common-center-div">
        {% if section.settings.heading %}
          <h2 class="doors-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading %}
          <p class="doors-subheading p-large color-primary">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="related-styles-grid doors-collection-grid">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection_picker] %}
        
        <a 
          class="related-style-card {% if block.settings.highlight %} highlighted {% endif %}"
          {% if collection %} href="{{ collection.url }}" {% endif %}
        >
          <div class="related-style-image">

            {% if block.settings.custom_image %}
              <img 
                src="{{ block.settings.custom_image | img_url: 'medium' }}" 
                alt="{{ collection.title }}"
              >
            {% elsif collection.image %}
              <img 
                src="{{ collection.image.src | img_url: 'medium' }}" 
                alt="{{ collection.title }}"
              >
            {% else %}
              <div class="doors-no-image">No Image</div>
            {% endif %}

          </div>

          <h3 class="doors-title related-style-title">
            {% if block.settings.custom_title != blank %}
              {{ block.settings.custom_title }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </h3>

              {% if block.settings.desc %}
              <p class="block-subheading related-styles-sub-heading">{{ block.settings.desc }}</p>
         {% endif %}

        </a>
      {% endfor %}
    </div>

    {% if section.settings.cta_text and section.settings.cta_link %}
      <div class="doors-cta-wrap">
        <a href="{{ section.settings.cta_link }}" class="doors-cta-btn common-btn btn-bordered">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  {% comment %} .doors-grid { display: flex; gap: 25px; margin-top: 30px; }
  .doors-item { flex: 1; text-decoration: none; color: inherit; }
  .doors-image-wrap img { width: 100%; border-radius: 8px; }
  .highlighted { border: 2px solid #000; padding: 10px; border-radius: 10px; }
  .doors-title { margin-top: 10px; font-size: 18px; font-weight: 600; }
  .doors-no-image { width: 100%; height: 200px; background: #eee; display: flex; align-items: center; justify-content: center; } {% endcomment %}



</style>

{% schema %}
{
  "name": "Doors Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every door, <em>built by hand</em>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether you're remodeling, restoring, or starting from scratch, we’ll craft a door that feels like it’s always been there."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "See All Products"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "door_item",
      "name": "Door Item",
      "settings": [
        {
          "type": "collection",
          "id": "collection_picker",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (optional)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (optional)"
        },
         {
            "type": "textarea",
            "id": "desc",
            "label": "Description"
                  },
        
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Doors Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

