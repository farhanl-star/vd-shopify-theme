<section class="hardware-showcase {{ section.settings.section_class}}" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="common-center-div {{ section.settings.mdiv_class }}">
      <h2 class="hardware-showcase__title {{ section.settings.heading_class }} color-primary">
        {{ section.settings.heading }} <i class="formated_text"> {{ section.settings.formated_text }}</i>
      </h2>
      {% if section.settings.subheading != blank %}
        <p class="hardware-showcase__subtitle p-large {{ section.settings.subheading_class }}">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
      {% if section.settings.headingDesc != blank %}
        <p class="hardware-showcase__desc text-left">
          {{ section.settings.headingDesc }}
        </p>
      {% endif %}
    </div>
    <div class="hardware-showcase__grid" data-hardware-grid>
      <div class="hardware-showcase__track hardware-showcase__carousel" data-hardware-track>
        {% for block in section.blocks %}
          <div class="hardware-showcase__item" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
              >
            {% endif %}
            <p class="hardware-showcase__item-title">
              {{ block.settings.title }}
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="hardware-showcase__dots" data-hardware-dots aria-hidden="true">
      {% for block in section.blocks %}
        <button type="button" class="hardware-showcase__dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}">
          <span class="visually-hidden">Slide {{ forloop.index }}</span>
        </button>
      {% endfor %}
    </div>
    {% if section.settings.button_text_1 != blank %}
      <div class="common-btn-div mt-40">
        <a
          href="{{ section.settings.button_link_1 | default: '#' }}"
          class="common-btn {{ section.settings.button_class_1 }}"
          {% if animated %}
            data-cascade
            style="--animation-order: 1;"
          {% endif %}
        >
          {{ section.settings.button_text_1 }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* Desktop: track is layout-transparent so grid still lays out items */
  .hardware-showcase__track {
    display: contents;
  }
  /* Mobile-only: carousel with next/previous slide overview (no loop) */
  @media screen and (max-width: 768px) {
    .hardware-showcase__grid {
      overflow: hidden;
      position: relative;
      touch-action: pan-y pinch-zoom;
    }
    .hardware-showcase__track.hardware-showcase__carousel {
      display: flex;
      flex-wrap: nowrap;
      transition: transform 0.35s ease-out;
      will-change: transform;
    }
    .hardware-showcase__grid .hardware-showcase__item {
      flex: 0 0 78%;
      min-width: 78%;
      width: 78%;
      box-sizing: border-box;
      scroll-snap-align: center;
    }
    .hardware-showcase__dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0;
    }
    .hardware-showcase__dot {
      width: 8px;
      height: 8px;
      padding: 0;
      border: 1px solid currentColor;
      border-radius: 50%;
      background: transparent;
      cursor: pointer;
      color: var(--color-primary, #806730);
      transition: background 0.2s;
    }
    .hardware-showcase__dot.is-active {
      background: currentColor;
    }
    .hardware-showcase__dot .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
  @media screen and (min-width: 769px) {
    .hardware-showcase__dots {
      display: none;
    }
  }
</style>

<script>
  (function () {
    const section = document.querySelector('.hardware-showcase[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const grid = section.querySelector('[data-hardware-grid]');
    const track = section.querySelector('[data-hardware-track]');
    const items = Array.from(section.querySelectorAll('.hardware-showcase__item'));
    const dotsWrap = section.querySelector('[data-hardware-dots]');
    const dotBtns = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.hardware-showcase__dot')) : [];

    const mobileQuery = window.matchMedia('(max-width: 768px)');
    function isMobile() { return mobileQuery.matches; }

    let currentIndex = 0;
    var slideWidthPercent = 78;

    function goToSlide(index) {
      if (index < 0 || index >= items.length) return;
      currentIndex = index;
      if (track) {
        track.style.transform = 'translateX(-' + (index * slideWidthPercent) + '%)';
      }
      dotBtns.forEach(function (btn, i) {
        btn.classList.toggle('is-active', i === index);
        btn.setAttribute('aria-current', i === index ? 'true' : 'false');
      });
    }

    /* Slider: swipe on track */
    if (grid) {
      var startX = 0, isDragging = false;
      grid.addEventListener('pointerdown', function (e) {
        startX = e.clientX;
        isDragging = true;
      }, { passive: true });
      grid.addEventListener('pointerup', function (e) {
        if (!isDragging) return;
        var diff = e.clientX - startX;
        if (diff > 60) goToSlide(currentIndex - 1);
        if (diff < -60) goToSlide(currentIndex + 1);
        isDragging = false;
      });
      grid.addEventListener('pointerleave', function () { isDragging = false; });
    }

    /* Slider: dot click changes slide */
    dotBtns.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var idx = parseInt(btn.getAttribute('data-index'), 10);
        if (!isNaN(idx)) goToSlide(idx);
      });
    });

    goToSlide(0);
  })();
</script>

{% schema %}
{
  "name": "Hardware Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hardware That Belongs"
    },
     {
      "type": "text",
      "id": "formated_text",
      "label": "Format text",
       "default": "Confidence"
    },
    {
      "type": "text",
      "id": "heading_class",
      "label": "Heading Class",
      "default": "h5"
    },
    {
      "type": "text",
      "id": "mdiv_class",
      "label": "Main Div Class",
      "default": "mb-40"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We’ve picked the kind we’d use in our own homes — tested for fit and finish"
    },
    {
      "type": "text",
      "id": "subheading_class",
      "label": "Subheading Class",
      "default": "mb-24"
    },
    {
      "type": "textarea",
      "id": "headingDesc",
      "label": "Heading Desc",
      "default": "We’ve picked the kind we’d use in our own homes — tested for fit and finish"
    },
    {
      "type": "text",
      "id": "button_text_1",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "button_class_1",
      "label": "Button Class",
      "default": "Add Class"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "section_class",
      "label": "Section Class",
      "default": "py-80"
    }
  ],
  "blocks": [
    {
      "type": "hardware",
      "name": "Hardware Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Hardware image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Hardware title",
          "default": "Albany Mortise Entry Set"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hardware That Belongs",
      "blocks": [
        { "type": "hardware" },
        { "type": "hardware" },
        { "type": "hardware" }
      ]
    }
  ]
}
{% endschema %}
