{%- comment -%}
  Section: Key Features Accordion (group-filtered)
  Shows only the accordion blocks whose "Group number" matches product metafield:
  product.metafields.custom.key_features_group (expected 1..30).
{%- endcomment -%}

{%- if product == blank -%}
  <div style="padding: 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 8px;">
    This section only works on product pages.
  </div>
{%- else -%}
  {%- assign group_value = '' -%}

  {%- comment -%}
    Read metafield value:
    - Supports number/text metafields
    - Normalizes to string and strips whitespace
  {%- endcomment -%}
  {%- assign mf = product.metafields.custom.key_features_group -%}
  {%- if mf != blank -%}
    {%- assign group_value = mf.value | default: mf | append: '' | strip -%}
  {%- endif -%}

  {%- if group_value != blank -%}
    <style>
      .kfa {
        --kfa-border: 1px solid rgba(0,0,0,0.10);
        --kfa-radius: 8px;
        --kfa-bg: #fff;
        --kfa-muted: rgba(0,0,0,0.64);
      }
      .kfa__item {
        background: var(--kfa-bg);
        border: var(--kfa-border);
        border-radius: var(--kfa-radius);
        overflow: hidden;
        margin: 0 0 12px 0;
      }
      .kfa__summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        font-weight: 700;
        user-select: none;
      }
      .kfa__summary::-webkit-details-marker { display: none; }
      .kfa__title { min-width: 0; }
      .kfa__icon {
        width: 16px;
        height: 16px;
        position: relative;
        flex: 0 0 auto;
      }
      .kfa__icon::before,
      .kfa__icon::after {
        content: "";
        position: absolute;
        left: 0;
        top: 7px;
        width: 16px;
        height: 2px;
        background: #00476C;
        border-radius: 2px;
      }
      .kfa__icon::after {
        transform: rotate(90deg);
        transition: opacity 160ms ease;
      }
      .kfa__item[open] .kfa__icon::after { opacity: 0; }
      .kfa__body {
        padding: 16px;
        border-top: var(--kfa-border);
      }
      .kfa__image img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 6px;
        margin: 0 0 12px 0;
      }
      .kfa__content { color: var(--kfa-muted); line-height: 1.45; }
    </style>

    {% render 'key-features-accordion', blocks: section.blocks, group_value: group_value %}
  {%- endif -%}

{%- endif -%}

{% schema %}
{
  "name": "Key features accordion",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "accordion",
