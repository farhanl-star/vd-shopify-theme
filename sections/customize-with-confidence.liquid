<section class="customize-confidence py-80">
  <div class="page-width container">

    <!-- Header -->
    <div class="customize-confidence__header common-center-div mb-40">
      <h4 class="customize-confidence__title">
        {{ section.settings.heading }}
      </h4>
      <p class="customize-confidence__subtitle common-header-desc">
        {{ section.settings.subheading }}
      </p>
    </div>

    <!-- Grid -->
    <div class="customize-confidence__grid">
      {% for block in section.blocks %}
        <div class="customize-confidence__item" {{ block.shopify_attributes }}>

          {% if block.settings.image %}
            <div class="customize-confidence__image">
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          <div class="customize-confidence__content">
          <h3 class="customize-confidence__item-title">
            {{ block.settings.title }}
          </h3>

          <p class="customize-confidence__item-text">
            {{ block.settings.text }}
          </p>

          {% if block.settings.link_label and block.settings.link %}
            <a href="{{ block.settings.link }}" class="customize-confidence__link common-btn common-link secondary" >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none"> 
                <g clip-path="url(#clip0_8678_58808)"> <path d="M8.03206 4.92998C7.79606 4.92998 7.60406 4.85398 7.45606 4.70198C7.30806 4.54598 7.23406 4.35398 7.23406 4.12598C7.23406 3.90198 7.30806 3.71398 7.45606 3.56199C7.60406 3.40998 7.79606 3.33398 8.03206 3.33398C8.27206 3.33398 8.46606 3.40998 8.61406 3.56199C8.76206 3.71398 8.83606 3.90198 8.83606 4.12598C8.83606 4.35398 8.76206 4.54598 8.61406 4.70198C8.46606 4.85398 8.27206 4.92998 8.03206 4.92998ZM8.68606 6.59198L8.64406 7.64799V11.338L9.51406 11.632V11.86H6.66406V11.632L7.52206 11.338V7.78598C7.47406 7.72599 7.40406 7.66599 7.31206 7.60598C7.22406 7.54598 7.12406 7.48799 7.01206 7.43198C6.90006 7.37599 6.78606 7.32799 6.67006 7.28799V7.08398L8.53006 6.59198H8.68606Z" fill="#806730"/>
                  <circle cx="8" cy="8" r="7.5" stroke="#806730"/> 
                </g> 
                <defs>
                  <clipPath id="clip0_8678_58808"> 
                    <rect width="18" height="18" fill="white"/> 
                  </clipPath> 
                </defs> \
              </svg> {{ block.settings.link_label }}
            </a>
          {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Footer CTA -->
    <div class="common-center-div pt-60">
      {% if section.settings.footer_heading %}
        <div class="customize-confidence__footer">
          <h6>{{ section.settings.footer_heading }}</h6>
          <p>{{ section.settings.footer_text }}</p>
        </div>
      {% endif %}

     {% if section.settings.link_label and section.settings.link %}
        <a href="{{ section.settings.link }}" class="customize-confidence__link common-btn mx-auto" >
          {{ section.settings.link_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customize With Confidence",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customize With Confidence"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every choice, clearly explained — so your door fits, functions, and feels like it was always part of your home."
    },
    {
      "type": "text",
      "id": "footer_heading",
      "label": "Footer heading",
      "default": "Ready to get started?"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer text",
      "default": "We’ll walk you through all the options that will make your door, yours."
    },
     {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Customize With Confidence",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}