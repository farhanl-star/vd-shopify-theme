              <img loading="lazy" width="19" height="19"  data-value="{{ country.iso_code }}" src="{{ 'Kuwait.png' | asset_url }}" alt="country">
             {% endif %}  
             
                 {% if country.iso_code contains 'BH' %}
                <img loading="lazy" width="19" height="19"  data-value="{{ localization.country.iso_code }}" src="{{ 'Bahrain.png' | asset_url }}" alt="country">
                 {% endif %}  
              
